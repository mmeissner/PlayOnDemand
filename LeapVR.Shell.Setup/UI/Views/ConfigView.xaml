<Window
    x:Class="LeapVR.Shell.Setup.UI.Views.ConfigView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="500"
    d:DesignWidth="600"
    lex:ResxLocalizationProvider.DefaultAssembly="LeapVR.Shell.Language"
    lex:ResxLocalizationProvider.DefaultDictionary="Resources"
    Background="{DynamicResource MaterialDesignPaper}"
    FontFamily="Microsoft YaHei"
    TextElement.FontSize="14"
    TextElement.FontWeight="Medium"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel
                Grid.Row="1"
                Orientation="Horizontal"
                ZIndex="1">
                <Label
                    Grid.Row="0"
                    Margin="5"
                    Content="{lex:Loc Config_Select_Language}" />
                <ComboBox
                    Name="AvailibleLanguages"
                    Grid.Row="0"
                    HorizontalAlignment="Right">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                </ComboBox>
            </StackPanel>
            <TextBlock
                Grid.Row="1"
                Margin="5"
                FontSize="25"
                FontWeight="DemiBold"
                Text="{lex:Loc Config_Software_Setup}"
                TextAlignment="Center" />
        </Grid>
        <materialDesign:Transitioner
            x:Name="Wizard"
            Grid.Row="1"
            SelectedIndex="0">
            <ContentControl Name="PathsPage" />
            <ContentControl Name="ApplyChangesPage" />
            <ContentControl Name="RegisterAccountPage" />
        </materialDesign:Transitioner>
        <UniformGrid
            Grid.Row="2"
            Columns="2"
            Visibility="{Binding NextPrevious}">
            <Button
                x:Name="MovePrevious"
                Height="50"
                Margin="5"
                Content="{lex:LocTextUpper Config_Move_Previous}"
                FontWeight="Bold" />
            <Button
                x:Name="MoveNext"
                Height="50"
                Margin="5"
                Content="{lex:LocTextUpper Config_Move_Next}"
                FontWeight="Bold" />
        </UniformGrid>
        <UniformGrid
            Grid.Row="3"
            Columns="1"
            Visibility="{Binding Finished}">
            <Button
                x:Name="CloseConfig"
                Height="50"
                Margin="5"
                Content="{lex:LocTextUpper Config_Close}"
                FontWeight="Bold" />
        </UniformGrid>
    </Grid>
</Window>