                    </StackPanel>
                </Grid>
            </-->
            <GroupBox
                Grid.Row="1" Grid.Column="0"
                Margin="5"
                Header="{lex:Loc Config_Options}"
                Style="{DynamicResource MaterialDesignCardGroupBox}">
                <GroupBox.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="32" Height="32" VerticalAlignment="Center" Kind="Gauge" />
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource MaterialDesignTitleTextBlock}" Text="{Binding}" />
                        </StackPanel>
                    </DataTemplate>
                </GroupBox.HeaderTemplate>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <UniformGrid Grid.Row="0" Margin="10" Columns="2">
                        <TextBlock FontSize="20" Text="{lex:Loc Config_Autostart_with_Windows}" />
                        <Viewbox Height="30" HorizontalAlignment="Right">
                            <ToggleButton x:Name="AutostartWithWindows" ToolTip="{lex:Loc Config_Autostart_with_Windows_ToolTip}" />
                        </Viewbox>
                    </UniformGrid>
                    <UniformGrid Grid.Row="1" Margin="10" Columns="2">
                        <TextBlock FontSize="20" Text="{lex:Loc Config_Disable_WER}" />
                        <Viewbox Height="30" HorizontalAlignment="Right">
                            <ToggleButton x:Name="DisableWindowsErrorReporting" ToolTip="{lex:Loc Config_Disable_WER_ToolTip}" />
                        </Viewbox>
                    </UniformGrid>
                    <UniformGrid Grid.Row="2" Margin="10" Columns="2" Visibility="{Binding IsPowerShellAvailible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock FontSize="20" Text="{lex:Loc Config_AddStorageToDefenderExclusion}" />
                        <Viewbox Height="30" HorizontalAlignment="Right">
                            <ToggleButton x:Name="ExcludeStorageFromWindowsDefender" ToolTip="{lex:Loc Config_ExcludingStorageFromWD_Hint}" />
                        </Viewbox>
                    </UniformGrid>
                    <UniformGrid Grid.Row="3" Columns="2">
                        <Label Margin="5" Content="{lex:Loc Config_Select_DefaultLanguage}" FontSize="20" />
                        <ComboBox
                            Name="Languages"
                            Grid.Row="0"
                            Width="200"
                            HorizontalAlignment="Right"
                            FontSize="20"
                            ToolTip="{lex:Loc Config_Select_DefaultLanguage_Hint}">
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                        </ComboBox>
                    </UniformGrid>
                </Grid>
            </GroupBox>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>