<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <!--
    SDK-style migration of the legacy LeapVR.Shell.Setup.csproj. The legacy
    csproj (kept as LeapVR.Shell.Setup.csproj.bak for VS 2022 17.14- builds)
    couldn't compile under `dotnet msbuild` because the WPF target chain
    (MarkupCompilePass1, PresentationBuildTasks) isn't loaded for legacy
    csprojs. SDK-style with UseWpf=true wires those targets cleanly.

    Convention-based file inclusion: all *.cs under the project dir are
    Compile-included by default; all *.xaml are Page-included with the
    DependentUpon binding inferred from filename match. Resource files +
    NuGet packages.config references converted to PackageReference below.
  -->

  <PropertyGroup>
    <TargetFramework>net471</TargetFramework>
    <OutputType>Library</OutputType>
    <UseWpf>true</UseWpf>
    <RootNamespace>LeapVR.Shell.Setup</RootNamespace>
    <AssemblyName>LeapVR.Shell.Setup</AssemblyName>
    <ProjectGuid>{E08728C9-D469-4BCC-9169-44AE0AD3343D}</ProjectGuid>
    <Configurations>Debug;Release;Release_ShellClient</Configurations>
    <Platforms>AnyCPU;x64</Platforms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <ImportWindowsDesktopTargets>true</ImportWindowsDesktopTargets>
    <!-- Legacy Properties\AssemblyInfo.cs uses [assembly: AssemblyVersion("2018.4.*")]
         which the deterministic-build C# compiler rejects. Allow wildcards. -->
    <Deterministic>false</Deterministic>
  </PropertyGroup>

  <!-- Don't let the SDK's auto-glob pick up the .bak file as Compile input. -->
  <ItemGroup>
    <Compile Remove="LeapVR.Shell.Setup.csproj.bak" />
    <None Remove="LeapVR.Shell.Setup.csproj.bak" />
  </ItemGroup>

  <!-- This project is a library (Library OutputType) consumed by LeapVR.Shell;
       the entry-point App.xaml/App.cs ship for the legacy WPF wiring but the
       SDK auto-converts App.xaml -> ApplicationDefinition by convention, which
       conflicts with Library OutputType. Force App.xaml back to a Page. -->
  <ItemGroup>
    <ApplicationDefinition Remove="App.xaml" />
    <Page Include="App.xaml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Caliburn.Micro" Version="3.2.0" />
    <PackageReference Include="Caliburn.Micro.Core" Version="3.2.0" />
    <PackageReference Include="Humanizer.Core" Version="2.2.0" />
    <PackageReference Include="Humanizer.Core.zh-CN" Version="2.2.0" />
    <PackageReference Include="MaterialDesignColors" Version="1.1.3" />
    <PackageReference Include="MaterialDesignThemes" Version="2.5.1" />
    <PackageReference Include="Microsoft.PowerShell.3.ReferenceAssemblies" Version="1.0.0" />
    <PackageReference Include="NLog" Version="4.5.11" />
    <PackageReference Include="SimpleInjector" Version="4.2.2" />
    <PackageReference Include="Windows7APICodePack-Core" Version="1.1.0.0" />
    <PackageReference Include="Windows7APICodePack-Shell" Version="1.1.0.0" />
    <PackageReference Include="WPFLocalizeExtension" Version="3.1.2" />
    <PackageReference Include="XAMLMarkupExtensions" Version="1.3.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\LeapVR.Shared.Lib.Wpf\LeapVR.Shared.Lib.Wpf.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Categories\LeapVR.Shell.Categories.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Controllers\LeapVR.Shell.Controllers.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Domain.Models\LeapVR.Shell.Domain.Models.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Language\LeapVR.Shell.Language.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Modules.Interfaces\LeapVR.Shell.Modules.Interfaces.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Modules\LeapVR.Shell.Modules.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Repository.Interfaces\LeapVR.Shell.Repository.Interfaces.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Repository\LeapVR.Shell.Repository.csproj" />
    <ProjectReference Include="..\LeapVR.Utilities.Windows\LeapVR.Utilities.Windows.csproj" />
  </ItemGroup>

</Project>
