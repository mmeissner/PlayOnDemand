<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <!--
    SDK-style migration of the legacy 1198-line LeapVR.Shell.csproj. Backup at
    LeapVR.Shell.csproj.bak. SDK-style with UseWpf=true wires the WPF target
    chain (MarkupCompilePass1/2, PresentationBuildTasks) cleanly under both
    full MSBuild (VS 2022 17.15+) and `dotnet msbuild` (.NET 10 SDK).

    Convention-based file inclusion: all *.cs auto-Compile, all *.xaml
    auto-Page (App.xaml stays as the ApplicationDefinition - OutputType=WinExe).
    Image resources under Resources\Images\* promoted to Resource items below.
  -->

  <PropertyGroup>
    <TargetFramework>net471</TargetFramework>
    <OutputType>WinExe</OutputType>
    <UseWpf>true</UseWpf>
    <RootNamespace>LeapVR.Shell</RootNamespace>
    <AssemblyName>LeapPlay.Shell</AssemblyName>
    <ProjectGuid>{1B19A330-2A7B-42B8-8C21-507548506B50}</ProjectGuid>
    <ApplicationIcon>favicon.ico</ApplicationIcon>
    <Configurations>Debug;Release;Release_ShellClient</Configurations>
    <Platforms>AnyCPU;x64</Platforms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <ImportWindowsDesktopTargets>true</ImportWindowsDesktopTargets>
    <Deterministic>false</Deterministic>
    <RunPostBuildEvent>Always</RunPostBuildEvent>
    <!-- Build_Free.bat anchors SHELL_BIN at bin\x64\Release_ShellClient\ (no TFM
         subfolder) and the Inno Setup installer source picks LeapPlay.Shell.exe
         from there. SDK-style defaults append $(TargetFramework) to the output
         path; turn that off so the artefacts land where the build/install
         tooling expects. -->
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="LeapVR.Shell.csproj.bak" />
    <None Remove="LeapVR.Shell.csproj.bak" />
    <!-- TabSystemViewModel.cs is [Obsolete("moved to AdministrationViewModel")] dead code
         that references namespaces excised from the OSS release (LeapVR.VBox,
         LeapVR.Universal, LeapVR.Shared.NetStandard, LeapVR.Shell.Core,
         LeapVR.Shell.UI.Abstract). The legacy csproj omitted it from <Compile Include>;
         SDK-style auto-glob picks it up, so we exclude it explicitly. -->
    <Compile Remove="UI\Shell\SystemAdministration\ViewModels\TabSystemViewModel.cs" />
  </ItemGroup>

  <!-- App.xaml is the WPF Application but the real entry point is Program.cs (Main()).
       The SDK auto-promotes App.xaml to <ApplicationDefinition>, which generates an
       Application.Main and collides with Program.Main (CS0017: more than one entry
       point). Demote App.xaml to <Page>, matching the legacy csproj's setup. -->
  <ItemGroup>
    <ApplicationDefinition Remove="App.xaml" />
    <Page Include="App.xaml" />
  </ItemGroup>

  <!-- Resources\Styles\ScrollBar.xaml references Microsoft.Windows.Themes.ScrollChrome
       which lives in PresentationFramework.Aero - WPF's classic Aero theme assembly.
       SDK-style doesn't auto-reference it; explicit. -->
  <ItemGroup>
    <Reference Include="PresentationFramework.Aero" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Caliburn.Micro" Version="3.2.0" />
    <PackageReference Include="Caliburn.Micro.Core" Version="3.2.0" />
    <PackageReference Include="FontAwesome.WPF" Version="4.7.0.9" />
    <PackageReference Include="Humanizer.Core" Version="2.2.0" />
    <PackageReference Include="Humanizer.Core.zh-CN" Version="2.2.0" />
    <PackageReference Include="LiveCharts" Version="0.9.6" />
    <PackageReference Include="LiveCharts.Wpf" Version="0.9.6" />
    <PackageReference Include="MaterialDesignColors" Version="1.1.3" />
    <PackageReference Include="MaterialDesignThemes" Version="2.5.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="NLog" Version="4.5.11" />
    <PackageReference Include="SciChart.Wpf.UI.Transitionz" Version="1.0.5" />
    <PackageReference Include="SimpleInjector" Version="4.2.2" />
    <PackageReference Include="System.Interactive.Async" Version="3.2.0" />
    <PackageReference Include="System.Reactive" Version="4.1.5" />
    <!-- Pulled in at the kiosk level so it lands in the runtime output dir.
         Several transitive resx-bearing assemblies (LeapVR.Shell.Categories,
         LeapVR.Shell.Language) use the pre-serialized resx writer, which
         needs System.Resources.Extensions at deserialization time. -->
    <PackageReference Include="System.Resources.Extensions" Version="9.0.0" />
    <PackageReference Include="System.Windows.Interactivity.WPF" Version="2.0.20525" />
    <PackageReference Include="Windows7APICodePack-Core" Version="1.1.0.0" />
    <PackageReference Include="Windows7APICodePack-Shell" Version="1.1.0.0" />
    <PackageReference Include="WPFLocalizeExtension" Version="3.1.2" />
    <PackageReference Include="XAMLMarkupExtensions" Version="1.3.0" />
    <PackageReference Include="ZKWeb.System.Drawing" Version="4.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\LeapVR.Content.Shared\LeapVR.Content.Shared.csproj" />
    <ProjectReference Include="..\LeapVR.Shared.Lib.Win\LeapVR.Shared.Lib.Win.csproj" />
    <ProjectReference Include="..\LeapVR.Shared.Lib.Wpf\LeapVR.Shared.Lib.Wpf.csproj" />
    <ProjectReference Include="..\LeapVR.Shared.Lib\LeapVR.Shared.Lib.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.3rdParty\ffmediaelement\Unosquare.FFME.Common\Unosquare.FFME.Common.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.3rdParty\ffmediaelement\Unosquare.FFME.Windows\Unosquare.FFME.Windows.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.3rdParty\FFmpeg.AutoGen\FFmpeg.AutoGen\FFmpeg.AutoGen.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.3rdParty\QRCoder\QRCoder\QRCoder.NET40.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Categories\LeapVR.Shell.Categories.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Domain.Models\LeapVR.Shell.Domain.Models.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Managers\LeapVR.Shell.Managers.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Modules.Interfaces\LeapVR.Shell.Modules.Interfaces.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Modules\LeapVR.Shell.Modules.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Repository.Interfaces\LeapVR.Shell.Repository.Interfaces.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Repository\LeapVR.Shell.Repository.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Language\LeapVR.Shell.Language.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Services\LeapVR.Shell.Services.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Controllers\LeapVR.Shell.Controllers.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.Setup\LeapVR.Shell.Setup.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.OpenVR.Wrapper\LeapVR.Shell.OpenVR.Wrapper.csproj" />
    <ProjectReference Include="..\LeapVR.Shell.3rdParty\XInputDotNet\XInputDotNetPure\XInputDotNetPure.csproj" />
    <ProjectReference Include="..\LeapVR.Utilities.Steam\LeapVR.Utilities.Steam.csproj" />
    <ProjectReference Include="..\LeapVR.Utilities.Windows\LeapVR.Utilities.Windows.csproj" />
    <ProjectReference Include="..\LeapVR.Utilities.VersionInfo\LeapVR.Utilities.VersionInfo.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="app.config" CopyToOutputDirectory="PreserveNewest" />
    <None Update="Debug_NLog.config" CopyToOutputDirectory="PreserveNewest" />
    <None Update="Release_Nlog.config" CopyToOutputDirectory="PreserveNewest" />
    <None Update="NLog.xsd" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Resources\Images\**" />
    <Resource Include="Resources\Images\**" />
    <!-- Sound effects loaded via SoundPlayerAction at runtime
         (pack://application:,,,/resources/*.wav). Without this Include, clicking
         Connect successfully triggers a button-sound playback that throws
         "Cannot locate resource 'resources/buttonclick.wav'" and shuts the
         kiosk down via OnApplicationDispatcherUnhandledException. -->
    <Resource Include="Resources\*.wav" />
    <!-- Background looping video for the Login screen's MediaPlayerView. The
         Inno installer copies $(SolutionDir)LeapVR.Shell.Build/Media into the
         install dir; mirror that for dev/debug builds so `dotnet build` runs
         of the kiosk find the file at ./Media/Background.mp4 and SetupDb
         AddVideoBackground seeds the LoginView_Background_Player playlist. -->
    <None Include="..\LeapVR.Shell.Build\Media\**" LinkBase="Media" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- PostBuildEvent rewritten as a Target with MSBuild Copy tasks. The legacy
       <PostBuildEvent> used $(ConfigurationName) which only expands under VS-
       driven builds (modern SDK-style uses $(Configuration)) and spawned a CMD
       shell with xcopy/goto/copy syntax, which fails when `dotnet build` runs
       under bash. The Copy task is cross-shell. The vr_desktop xcopy is wrapped
       in an Exists() check so the build is graceful when the 141 MB Unity
       binary isn't dropped into LeapVR.Shell.3rdParty/bin/ yet. -->
  <Target Name="PodCopyVrDesktopAndNlogConfig" AfterTargets="Build">
    <ItemGroup Condition="Exists('$(SolutionDir)LeapVR.Shell.3rdParty\bin\vr_desktop')">
      <_PodVrDesktopFiles Include="$(SolutionDir)LeapVR.Shell.3rdParty\bin\vr_desktop\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_PodVrDesktopFiles)"
          DestinationFiles="@(_PodVrDesktopFiles->'$(TargetDir)vr_desktop\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(ProjectDir)Release_Nlog.config"
          DestinationFiles="$(TargetDir)$(TargetName).exe.nlog"
          Condition="'$(Configuration)' == 'Release_ShellClient' AND Exists('$(ProjectDir)Release_Nlog.config')" />
    <Copy SourceFiles="$(ProjectDir)Debug_NLog.config"
          DestinationFiles="$(TargetDir)$(TargetName).exe.nlog"
          Condition="('$(Configuration)' == 'Debug' OR '$(Configuration)' == 'Offline_Debug' OR '$(Configuration)' == 'Home_Debug') AND Exists('$(ProjectDir)Debug_NLog.config')" />
  </Target>

</Project>
