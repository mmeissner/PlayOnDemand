    <Style TargetType="{x:Type local:ToggleImage}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ToggleImage}">
                    <Viewbox Cursor="Arrow">
                        <Image x:Name="StateImage" Source="{TemplateBinding OffImage}" />
                    </Viewbox>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="StateImage" Property="Source" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=OnImage}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
