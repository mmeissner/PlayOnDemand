    <Style TargetType="{x:Type local:SwitchButton}">
        <Style.Resources>
            <DropShadowEffect
                x:Key="DropShadowEffect"
                BlurRadius="1" Direction="98" RenderingBias="Quality" ShadowDepth="0.5" />
        </Style.Resources>

        <Setter Property="Background" Value="#1c232d" />
        <Setter Property="Foreground" Value="#FF5AC75A" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="SwitchOffText" Value="OFF" />
        <Setter Property="SwitchOnText" Value="ON" />
        <Setter Property="IsSwitchOn" Value="False" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SwitchButton}">
                    <Viewbox>
                        <Border x:Name="PART_Root">
                            <Border.Clip>
                                <RectangleGeometry RadiusX="30" RadiusY="30" Rect="0,0,180,60" />
                            </Border.Clip>
                            <Grid>
                                <Grid x:Name="PART_SwitchOFF">
                                    <Border Width="180" Height="60" Background="{TemplateBinding Background}" CornerRadius="25">
                                        <TextBlock
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            FontSize="20" FontWeight="Bold"
                                            Foreground="{TemplateBinding TextColor}"
                                            Text="{TemplateBinding SwitchOffText}" />
                                    </Border>
                                </Grid>
                                <Grid x:Name="PART_SwitchON" Margin="-120,0,120,0">
                                    <Border Width="180" Height="60" Background="{TemplateBinding Foreground}" CornerRadius="25">

                                        <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
                                            <Path x:Name="Circle" Width="60" Height="60" DockPanel.Dock="Right">
                                                <Path.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Offset="1" Color="#FFF1F1F1" />
                                                        <GradientStop Color="White" />
                                                    </RadialGradientBrush>
                                                </Path.Fill>
                                                <Path.Data>
                                                    <EllipseGeometry Center="30,30" RadiusX="30" RadiusY="30" />
                                                </Path.Data>
                                                <Path.Effect>
                                                    <DropShadowEffect ShadowDepth="1" />
                                                </Path.Effect>
                                            </Path>

                                            <TextBlock
                                                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                DockPanel.Dock="Right" FontSize="20" FontWeight="Bold"
                                                Foreground="{TemplateBinding TextColor}"
                                                Text="{TemplateBinding SwitchOnText}"
                                                TextAlignment="Center" />

                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Viewbox>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSwitchOn" Value="True">
                            <Setter TargetName="PART_SwitchON" Property="Margin" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

