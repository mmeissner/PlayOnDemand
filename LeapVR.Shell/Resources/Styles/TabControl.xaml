<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:fa="http://schemas.fontawesome.io/icons/" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    mc:Ignorable="d">

    <ControlTemplate x:Key="DefaultScrollLeftButtonTemplate">
        <Button Margin="20,0,20,0" VerticalAlignment="Center" Style="{DynamicResource ButtonBaseStyle}">
            <fa:FontAwesome FontSize="{DynamicResource H2}" Icon="ChevronCircleLeft" />
        </Button>
    </ControlTemplate>

    <ControlTemplate x:Key="DefaultScrollRightButtonTemplate">
        <Button Margin="20,0,20,0" VerticalAlignment="Center" Style="{DynamicResource ButtonBaseStyle}">
            <fa:FontAwesome FontSize="{DynamicResource H2}" Icon="ChevronCircleRight" />
        </Button>
    </ControlTemplate>


    <Style x:Key="TabControlStyle" TargetType="{x:Type usercontrols:LeapTabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
        <Setter Property="ScrollLeftButtonTemplate" Value="{DynamicResource DefaultScrollLeftButtonTemplate}" />
        <Setter Property="ScrollRightButtonTemplate" Value="{DynamicResource DefaultScrollRightButtonTemplate}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type usercontrols:LeapTabControl}">
                    <Grid x:Name="templateRoot" ClipToBounds="true" KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="true">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ColumnDefinition0" />
                            <ColumnDefinition x:Name="ColumnDefinition1" Width="0" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="RowDefinition0" Height="Auto" />
                            <RowDefinition x:Name="RowDefinition1" Height="*" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="PART_Header" Grid.Row="0" Visibility="{TemplateBinding HeaderVisibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <usercontrols:MultifunctionalScrollViewer
                                x:Name="headerPanel"
                                Grid.Column="1"
                                EnableColumns="False"
                                HorizontalVisibility="{TemplateBinding ScrollViewer.CanContentScroll,
                                                                       Converter={StaticResource BoolToVisibilityConverter}}"
                                ScrollDownButtonTemplate="{TemplateBinding ScrollDownButtonTemplate}"
                                ScrollLeftButtonTemplate="{TemplateBinding ScrollLeftButtonTemplate}"
                                ScrollRightButtonTemplate="{TemplateBinding ScrollRightButtonTemplate}"
                                ScrollUpButtonTemplate="{TemplateBinding ScrollUpButtonTemplate}"
                                VerticalVisibility="Collapsed" VirtualizingPanel.ScrollUnit="Item">
                                <UniformGrid
                                    Margin="0"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    Panel.ZIndex="1"
                                    Background="Transparent" IsItemsHost="true" KeyboardNavigation.TabIndex="1" Rows="1" />

                            </usercontrols:MultifunctionalScrollViewer>
                        </Grid>

                        <Border
                            x:Name="contentPanel"
                            Grid.Row="1" Grid.Column="0"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            KeyboardNavigation.DirectionalNavigation="Contained" KeyboardNavigation.TabIndex="2" KeyboardNavigation.TabNavigation="Local">
                            <ContentPresenter
                                x:Name="PART_SelectedContentHost"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                ContentSource="SelectedContent"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="TabStripPlacement" Value="Bottom">
                            <Setter TargetName="headerPanel" Property="Grid.Row" Value="1" />
                            <Setter TargetName="contentPanel" Property="Grid.Row" Value="0" />
                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                            <Setter TargetName="RowDefinition1" Property="Height" Value="Auto" />
                            <Setter TargetName="headerPanel" Property="Margin" Value="2,0,2,2" />
                        </Trigger>
                        <Trigger Property="TabStripPlacement" Value="Left">
                            <Setter TargetName="headerPanel" Property="Grid.Row" Value="0" />
                            <Setter TargetName="contentPanel" Property="Grid.Row" Value="0" />
                            <Setter TargetName="headerPanel" Property="Grid.Column" Value="0" />
                            <Setter TargetName="contentPanel" Property="Grid.Column" Value="1" />
                            <Setter TargetName="ColumnDefinition0" Property="Width" Value="Auto" />
                            <Setter TargetName="ColumnDefinition1" Property="Width" Value="*" />
                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                            <Setter TargetName="RowDefinition1" Property="Height" Value="0" />
                            <Setter TargetName="headerPanel" Property="Margin" Value="2,2,0,2" />
                        </Trigger>
                        <Trigger Property="TabStripPlacement" Value="Right">
                            <Setter TargetName="headerPanel" Property="Grid.Row" Value="0" />
                            <Setter TargetName="contentPanel" Property="Grid.Row" Value="0" />
                            <Setter TargetName="headerPanel" Property="Grid.Column" Value="1" />
                            <Setter TargetName="contentPanel" Property="Grid.Column" Value="0" />
                            <Setter TargetName="ColumnDefinition0" Property="Width" Value="*" />
                            <Setter TargetName="ColumnDefinition1" Property="Width" Value="Auto" />
                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                            <Setter TargetName="RowDefinition1" Property="Height" Value="0" />
                            <Setter TargetName="headerPanel" Property="Margin" Value="0,2,2,2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="templateRoot" Property="TextElement.Foreground" Value="{DynamicResource ThemeDisabledTextColor}" />
                            <Setter Property="Background" Value="Transparent" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>