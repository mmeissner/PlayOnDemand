<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:system="clr-namespace:System;assembly=mscorlib" xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols">

    <system:Double x:Key="FontSize">40</system:Double>
    <Thickness x:Key="Margin">5</Thickness>
    <CornerRadius x:Key="CornerRadius">15</CornerRadius>
    <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="3" Direction="-90" ShadowDepth="1" />

    <Style x:Key="Button" TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource CornerRadius}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            x:Name="contentPresenter"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentStringFormat="{TemplateBinding ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Focusable="False" RecognizesAccessKey="True"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Button.IsDefaulted" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <!--<Setter Property="Background" TargetName="border" Value="#FFBEE6FD"/>-->
                            <Setter TargetName="border" Property="BorderBrush" Value="#FF3C7FB1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <!--<Setter Property="Background" TargetName="border" Value="#FFC4E5F6"/>-->
                            <Setter TargetName="border" Property="BorderBrush" Value="#FF2C628B" />
                        </Trigger>
                        <Trigger Property="ToggleButton.IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FFBCDDEE" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#FF245A83" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#FFF4F4F4" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#FFADB2B5" />
                            <Setter TargetName="contentPresenter" Property="TextElement.Foreground" Value="#FF838383" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DigitButton" BasedOn="{StaticResource Button}" TargetType="Button">
        <Setter Property="Margin" Value="{StaticResource Margin}" />
        <Setter Property="Effect" Value="{StaticResource DropShadowEffect}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="#353535" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <!--  Workaround for ATI video cards that don't render good with dropshadoweffect  -->
                <RotateTransform Angle="0.00000000001" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF252525" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="Black" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FeatureButton" BasedOn="{StaticResource Button}" TargetType="Button">
        <Setter Property="Margin" Value="{StaticResource Margin}" />
        <Setter Property="Effect" Value="{StaticResource DropShadowEffect}" />
        <Setter Property="BorderBrush" Value="{x:Null}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="{StaticResource FontSize}" />
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="Background" Value="White" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <!--  Workaround for ATI video cards that don't render good with dropshadoweffect  -->
                <RotateTransform Angle="0.00000000001" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FFDEDEDE" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="DarkGray" />
            </Trigger>
        </Style.Triggers>
    </Style>


    <Style TargetType="{x:Type usercontrols:KeyPad}">
        <Setter Property="DisplayAreaVisibility" Value="Visible" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type usercontrols:KeyPad}">
                    <Border x:Name="PART_KeyPanel" Background="#e9e9e9" CornerRadius="20">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <Border
                                x:Name="DisplayArea"
                                Grid.Row="0"
                                Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.17}"
                                Margin="30,30,30,10"
                                Background="#353535"
                                CornerRadius="{StaticResource CornerRadius}"
                                Effect="{StaticResource DropShadowEffect}"
                                Visibility="{TemplateBinding DisplayAreaVisibility}">
                                <TextBox
                                    x:Name="PART_InputElement"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Focusable="True"
                                    FontSize="{StaticResource FontSize}"
                                    Foreground="White" IsReadOnly="True"
                                    Text="{TemplateBinding DisplayText}"
                                    TextAlignment="Center" />
                            </Border>

                            <Grid x:Name="InputArea" Grid.Row="1" Margin="30,10,30,30">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <Button
                                    x:Name="PART_Button_1"
                                    Grid.Row="0" Grid.Column="0"
                                    Content="1" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="75" />
                                <Button
                                    x:Name="PART_Button_2"
                                    Grid.Row="0" Grid.Column="1"
                                    Content="2" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="76" />
                                <Button
                                    x:Name="PART_Button_3"
                                    Grid.Row="0" Grid.Column="2"
                                    Content="3" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="77" />
                                <Button
                                    x:Name="PART_Button_Back"
                                    Grid.Row="0" Grid.Column="3"
                                    Focusable="False"
                                    Style="{StaticResource FeatureButton}"
                                    Tag="2">
                                    <Path
                                        Width="72" Height="48"
                                        Data="F1M555.0371,274.4893L552.7871,276.7383L549.9861,273.9373L547.1991,276.7243L545.1131,274.6393L547.9001,271.8523L545.0101,268.9603L547.2601,266.7113L550.1501,269.6023L552.8921,266.8613L554.9761,268.9463L552.2361,271.6883z M555.3751,264.0003L544.8751,264.0003C543.1251,264.1253,535.0001,270.7503,535.0001,272.2503C535.0001,273.7503,543.1251,279.3753,544.8751,279.5003L555.3751,279.5003C558.8751,279.5003,559.3751,277.7093,559.3751,275.5003L559.3751,268.0003C559.3751,265.7913,558.7501,264.0003,555.3751,264.0003" Fill="#FF333333" Stretch="Fill" />
                                </Button>
                                <Button
                                    x:Name="PART_Button_4"
                                    Grid.Row="1" Grid.Column="0"
                                    Content="4" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="78" />
                                <Button
                                    x:Name="PART_Button_5"
                                    Grid.Row="1" Grid.Column="1"
                                    Content="5" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="79" />
                                <Button
                                    x:Name="PART_Button_6"
                                    Grid.Row="1" Grid.Column="2"
                                    Content="6" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="80" />
                                <Button
                                    x:Name="PART_Button_Clear"
                                    Grid.Row="1" Grid.Column="3"
                                    Content="C" Focusable="False"
                                    Style="{StaticResource FeatureButton}"
                                    Tag="5" />
                                <Button
                                    x:Name="PART_Button_7"
                                    Grid.Row="2" Grid.Column="0"
                                    Content="7" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="81" />
                                <Button
                                    x:Name="PART_Button_8"
                                    Grid.Row="2" Grid.Column="1"
                                    Content="8" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="82" />
                                <Button
                                    x:Name="PART_Button_9"
                                    Grid.Row="2" Grid.Column="2"
                                    Content="9" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="83" />
                                <Button
                                    x:Name="PART_Button_Enter"
                                    Grid.Row="2" Grid.RowSpan="2" Grid.Column="3"
                                    Content="OK" Focusable="False"
                                    Style="{StaticResource FeatureButton}"
                                    Tag="6" />
                                <Button
                                    x:Name="PART_Button_0"
                                    Grid.Row="3" Grid.Column="1"
                                    Content="0" Focusable="False"
                                    Style="{StaticResource DigitButton}"
                                    Tag="74" />


                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="DisplayAreaVisibility" Value="Visible">
                            <Setter TargetName="DisplayArea" Property="Margin" Value="30,30,30,10" />
                            <Setter TargetName="InputArea" Property="Margin" Value="30,10,30,30" />
                        </Trigger>
                        <Trigger Property="DisplayAreaVisibility" Value="Collapsed">
                            <Setter TargetName="DisplayArea" Property="Margin" Value="0" />
                            <Setter TargetName="InputArea" Property="Margin" Value="30" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>