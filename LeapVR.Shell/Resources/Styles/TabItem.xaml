<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="TabItemWithIconStyle" TargetType="{x:Type TabItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeMainTextColor}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="{DynamicResource H4}" />
        <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="UseLayoutRounding" Value="False" />
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}">
                        <ContentPresenter.LayoutTransform>
                            <RotateTransform Angle="0" />
                        </ContentPresenter.LayoutTransform>
                    </ContentPresenter>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TabItemStyleHorizontalLevel1" BasedOn="{StaticResource TabItemWithIconStyle}" TargetType="{x:Type TabItem}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Width" Value="330" />
        <Setter Property="Height" Value="100" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template" Value="{DynamicResource TabItemTemplateWithLineAboveLevel1}" />
    </Style>

    <Style x:Key="TabItemStyleVerticalLevel1" BasedOn="{StaticResource TabItemWithIconStyle}" TargetType="{x:Type TabItem}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Width" Value="320" />
        <Setter Property="Height" Value="90" />
        <Setter Property="Margin" Value="0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="{DynamicResource H5}" />
        <Setter Property="Template" Value="{DynamicResource TabItemTemplateWithLineAboveLevel1}" />

    </Style>

    <Style x:Key="TabItemStyleHorizontalLevel2" BasedOn="{StaticResource TabItemWithIconStyle}" TargetType="{x:Type TabItem}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <!--<Setter Property="Width" Value="300"/>-->
        <Setter Property="Height" Value="80" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="{DynamicResource H5}" />
        <Setter Property="Template" Value="{DynamicResource TabItemTemplateWithLineAboveLevel2}" />

    </Style>

    <ControlTemplate x:Key="TabItemTemplateWithColorBlockLevel1" TargetType="TabItem">
        <Border
            Name="Border"
            Margin="{TemplateBinding Margin}"
            Padding="{TemplateBinding Padding}"
            HorizontalAlignment="Stretch"
            Background="{TemplateBinding Background}"
            BorderThickness="{TemplateBinding BorderThickness}">
            <DockPanel HorizontalAlignment="{TemplateBinding HorizontalAlignment}" LastChildFill="False">
                <Border
                    Width="60" Height="60"
                    Margin="10,0,10,0" Padding="15"
                    Background="Gray" CornerRadius="15" DockPanel.Dock="Left"
                    Visibility="{Binding Path=Source, ElementName=icon, Converter={StaticResource NullToVisibilityConverter}}">
                    <Image x:Name="icon" Source="{Binding IconKey, Converter={StaticResource KeyToCorrespondingIconConverter}}" />
                </Border>
                <ContentPresenter
                    x:Name="ContentSite"
                    Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                    ContentSource="Header" DockPanel.Dock="Left" RecognizesAccessKey="True" />
            </DockPanel>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="Black" />
                <Setter TargetName="Border" Property="Background" Value="White" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ThemeDisabledTextColor}" />
                <Setter TargetName="Border" Property="Background" Value="Transparent" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="true" />
                    <Condition Property="IsSelected" Value="false" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeHighlightBackgroundColor}" />
            </MultiTrigger>
            <Trigger Property="IsMouseOver" Value="true" />
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="TabItemTemplateWithColorBlockLevel2" TargetType="{x:Type TabItem}">
        <Grid>
            <Border
                Name="Border"
                Margin="{TemplateBinding Margin}"
                Padding="{TemplateBinding Padding}"
                HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                Background="{TemplateBinding Background}"
                BorderThickness="{TemplateBinding BorderThickness}">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <Border
                        Width="45" Height="45"
                        Margin="10,0,10,0" Padding="15"
                        Background="Gray" CornerRadius="15"
                        Visibility="{Binding Path=Source, ElementName=icon, Converter={StaticResource NullToVisibilityConverter}}">
                        <Image x:Name="icon" Source="{Binding IconKey, Converter={StaticResource KeyToCorrespondingIconConverter}}" />
                    </Border>
                    <ContentPresenter
                        x:Name="ContentSite"
                        Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                        ContentSource="Header" RecognizesAccessKey="True" />
                </StackPanel>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="Black" />
                <Setter TargetName="Border" Property="Background" Value="White" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Border" Property="Background" Value="Black" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="true" />
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="TabItemTemplateWithLineAboveLevel1" TargetType="TabItem">
        <Border
            Name="Border"
            Margin="{TemplateBinding Margin}"
            Padding="{TemplateBinding Padding}"
            HorizontalAlignment="Stretch"
            Background="{TemplateBinding Background}"
            BorderThickness="{TemplateBinding BorderThickness}">
            <DockPanel>
                <Rectangle
                    x:Name="Line"
                    Height="5"
                    Margin="5" HorizontalAlignment="Stretch"
                    DockPanel.Dock="Top"
                    Fill="{DynamicResource ThemeMainTextColor}"
                    Visibility="Hidden" />
                <DockPanel HorizontalAlignment="{TemplateBinding HorizontalAlignment}" DockPanel.Dock="Top">
                    <Image
                        x:Name="icon"
                        Width="45" Height="45"
                        Margin="20,0"
                        Source="{Binding IconKey, Converter={StaticResource KeyToCorrespondingIconConverter}}"
                        Stretch="Uniform" />
                    <ContentPresenter
                        x:Name="ContentSite"
                        Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                        ContentSource="Header" Focusable="True" RecognizesAccessKey="True" />
                </DockPanel>
            </DockPanel>
        </Border>

        <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Line" Property="Visibility" Value="Visible" />
                <Setter Property="TextElement.FontWeight" Value="Bold" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ThemeDisabledTextColor}" />
                <Setter TargetName="Border" Property="Background" Value="Transparent" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="true" />
                    <Condition Property="IsSelected" Value="false" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Line" Property="Visibility" Value="Visible" />
                <Setter TargetName="Line" Property="Fill" Value="{DynamicResource ThemeDisabledTextColor}" />
            </MultiTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="true" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Panel.ZIndex" Value="1" />
            </MultiDataTrigger>

            <Trigger Property="IsMouseOver" Value="true" />
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="TabItemTemplateWithLineAboveLevel2" TargetType="TabItem">
        <Grid x:Name="root" Width="Auto">
            <Border
                Name="Border"
                Margin="{TemplateBinding Margin}"
                Padding="{TemplateBinding Padding}"
                HorizontalAlignment="Stretch"
                Background="{TemplateBinding Background}"
                BorderThickness="{TemplateBinding BorderThickness}">
                <DockPanel HorizontalAlignment="Stretch">
                    <Rectangle
                        x:Name="Line"
                        Height="5"
                        Margin="5" HorizontalAlignment="Stretch"
                        DockPanel.Dock="Top"
                        Fill="{DynamicResource ThemeMainTextColor}"
                        Visibility="Hidden" />
                    <StackPanel HorizontalAlignment="Center" DockPanel.Dock="Top" Orientation="Horizontal">
                        <Image
                            x:Name="icon"
                            Width="45" Height="45"
                            Margin="20,0"
                            Source="{Binding IconKey, Converter={StaticResource KeyToCorrespondingIconConverter}}"
                            Stretch="Uniform" />
                        <ContentPresenter
                            x:Name="ContentSite"
                            Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                            ContentSource="Header" RecognizesAccessKey="True" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Line" Property="Visibility" Value="Visible" />
                <Setter Property="TextElement.FontWeight" Value="Bold" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ThemeDisabledTextColor}" />
                <Setter TargetName="Border" Property="Background" Value="Transparent" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="true" />
                    <Condition Property="IsSelected" Value="false" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Line" Property="Visibility" Value="Visible" />
                <Setter TargetName="Line" Property="Fill" Value="{DynamicResource ThemeDisabledTextColor}" />
            </MultiTrigger>
            <Trigger Property="IsMouseOver" Value="true" />
        </ControlTemplate.Triggers>
    </ControlTemplate>


</ResourceDictionary>