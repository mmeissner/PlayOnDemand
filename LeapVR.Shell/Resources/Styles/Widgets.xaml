<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:properties="clr-namespace:LeapVR.Shell.Properties">
    <DataTemplate x:Key="InstallationLoadingItem">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" Grid.Column="0" Margin="5">
                <UserControl
                    x:Name="spinner"
                    Width="92" Height="43"
                    HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center"
                    Template="{DynamicResource AppleSpinner}" />
            </Border>
            <TextBlock
                Grid.Row="0" Grid.Column="1"
                Margin="5,0,5,0" HorizontalAlignment="Left"
                FontSize="{DynamicResource H5}"
                Style="{DynamicResource TextBlockBaseStyle}"
                Text="{lex:Loc Global_Loading}" />
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Path=Visibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Visible">
                <Setter TargetName="spinner" Property="Visibility" Value="Visible" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=Visibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Collapsed">
                <Setter TargetName="spinner" Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=Visibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Hidden">
                <Setter TargetName="spinner" Property="Visibility" Value="Hidden" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>


</ResourceDictionary>