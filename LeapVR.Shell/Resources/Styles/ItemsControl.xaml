<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols">

    <!--  default style of ListView  -->
    <Style x:Key="ListViewStyleBase" TargetType="{x:Type ListView}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource SessionViewsPrimaryBorderColor}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource SessionViewsPrimaryForegroundColor}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
        <!--<Setter Property="ScrollViewer.PanningMode" Value="Both"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>-->
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ItemsControlStyleBase" TargetType="{x:Type ItemsControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderColor}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeMainTextColor}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
        <!--<Setter Property="ScrollViewer.PanningMode" Value="Both"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>-->
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>


    <!--  style for listview without columns style  -->
    <Style x:Key="ListViewStyleWithoutColumns" BasedOn="{StaticResource ListViewStyleBase}" TargetType="{x:Type ListView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListView}">
                    <Border
                        x:Name="Bd"
                        Padding="1"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="true">
                        <usercontrols:MultifunctionalScrollViewer EnableColumns="False" HorizontalVisibility="Collapsed" VerticalVisibility="Visible">
                            <usercontrols:MultifunctionalScrollViewer.ScrollUpButtonTemplate>
                                <ControlTemplate>
                                    <Border Background="{DynamicResource ThemeMainTextColor}">
                                        <Image Height="25" Source="{StaticResource IconScrollUp}" />
                                    </Border>
                                </ControlTemplate>
                            </usercontrols:MultifunctionalScrollViewer.ScrollUpButtonTemplate>
                            <usercontrols:MultifunctionalScrollViewer.ScrollDownButtonTemplate>
                                <ControlTemplate>
                                    <Border Background="{DynamicResource ThemeMainTextColor}">
                                        <Image Height="25" Source="{StaticResource IconScrollDown}" />
                                    </Border>
                                </ControlTemplate>
                            </usercontrols:MultifunctionalScrollViewer.ScrollDownButtonTemplate>
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </usercontrols:MultifunctionalScrollViewer>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="Bd" Property="Background" Value="Transparent" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeDisabledTextColor}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsGrouping" Value="true" />
                                <Condition Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="false" />
                            </MultiTrigger.Conditions>
                            <Setter Property="ScrollViewer.CanContentScroll" Value="false" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

