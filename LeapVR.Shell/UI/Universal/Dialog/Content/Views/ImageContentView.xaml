<UserControl
    x:Class="LeapVR.Shell.UI.Universal.ContentHolder.Views.ImageContentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:LeapVR.Shell.UI.Universal.ContentHolder.Views" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">

        <TextBlock Style="{DynamicResource TextBlockBaseStyle}" Text="{Binding StringContent, Mode=OneWay}" />

        <Image Margin="20" Source="{Binding ImageContent, Mode=OneWay}" />

    </StackPanel>
</UserControl>
