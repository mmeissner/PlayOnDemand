<UserControl
    x:Class="LeapVR.Shell.UI.Universal.Dialog.Views.ConfirmationDialogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    BorderBrush="{DynamicResource ThemeBorderColor}"
    BorderThickness="3"
    mc:Ignorable="d">
    <UserControl.Background>
        <ImageBrush ImageSource="{DynamicResource ImageShellBlockingBackground}" Stretch="UniformToFill" />
    </UserControl.Background>

    <Grid x:Name="ConfirmationDialog">
        <!--Grid.Background>
            <ImageBrush ImageSource="{DynamicResource OverlayBackground}" />
        </-->
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <ContentControl
            x:Name="DisplayContent"
            Grid.Row="1"
            MaxWidth="840"
            Margin="50"
            HorizontalAlignment="Center"
            FontSize="{DynamicResource GuardViewsH4}" />

        <UniformGrid
            Grid.Row="2"
            Margin="50,0"
            Columns="2"
            FlowDirection="RightToLeft"
            Rows="1">

            <usercontrols:LeapButton
                x:Name="Cancel"
                Margin="20"
                Padding="100,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                Focusable="True"
                FontSize="{DynamicResource GuardViewsH4}"
                Style="{DynamicResource GuardViewsButtonStyle}">

                <usercontrols:LeapButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,15,0"
                            VerticalAlignment="Center"
                            Text="{lex:Loc Global_Cancel}" />
                        <TextBlock VerticalAlignment="Center" Visibility="{Binding EnableGamepadIndicator, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock.Inlines>
                                <Image
                                    Width="45"
                                    Height="45"
                                    Source="{DynamicResource IconXboxControllerB}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                    </StackPanel>
                </usercontrols:LeapButton.Content>
            </usercontrols:LeapButton>

            <usercontrols:LeapButton
                x:Name="Confirm"
                Margin="20"
                Padding="100,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                Focusable="True"
                FontSize="{DynamicResource GuardViewsH4}"
                Style="{DynamicResource GuardViewsButtonStyle}"
                Visibility="{Binding IsCancelOnly, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">

                <usercontrols:LeapButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,15,0"
                            VerticalAlignment="Center"
                            Text="{lex:Loc Global_Confirm}" />
                        <TextBlock VerticalAlignment="Center" Visibility="{Binding EnableGamepadIndicator, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock.Inlines>
                                <Image
                                    Width="45"
                                    Height="45"
                                    Source="{DynamicResource IconXboxControllerA}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                    </StackPanel>
                </usercontrols:LeapButton.Content>

            </usercontrols:LeapButton>

        </UniformGrid>
    </Grid>
</UserControl>
