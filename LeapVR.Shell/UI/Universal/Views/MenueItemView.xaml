<UserControl
    x:Class="LeapVR.Shell.UI.Universal.Views.MenueItemView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:fa="http://schemas.fontawesome.io/icons/" xmlns:local="clr-namespace:LeapVR.Shell.UI.Universal.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="413" d:DesignWidth="413"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Button
            x:Name="MenueAction"
            Grid.Row="0"
            Margin="0"
            BorderThickness="0" Focusable="False"
            IsEnabled="{Binding IsEnabled}">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}" BorderBrush="Black" BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid Margin="12">
                <fa:ImageAwesome
                    Width="200"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10"
                    Foreground="White" Icon="Spinner" Opacity="1"
                    Spin="{Binding IsBusy}"
                    SpinDuration="5"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                <Image x:Name="DefaultImage" Width="400" Height="400" Stretch="Uniform">
                    <!--  Visibility="{Binding IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}"  -->
                    <Image.Visibility>
                        <MultiBinding Converter="{StaticResource MenueItemAndBusyToVisibilityConverter}" ConverterParameter="false">
                            <Binding Path="IsActive" />
                            <Binding Path="IsBusy" />
                        </MultiBinding>
                    </Image.Visibility>
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <Image x:Name="SelectedImage" Width="400" Height="400" Stretch="Uniform">
                    <Image.Visibility>
                        <MultiBinding Converter="{StaticResource MenueItemAndBusyToVisibilityConverter}" ConverterParameter="true">
                            <Binding Path="IsActive" />
                            <Binding Path="IsBusy" />
                        </MultiBinding>
                    </Image.Visibility>
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.1" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
            </Grid>
        </Button>
    </Grid>
</UserControl>