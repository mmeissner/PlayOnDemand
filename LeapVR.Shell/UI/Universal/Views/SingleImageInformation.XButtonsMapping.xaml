<UserControl
    x:Class="LeapVR.Shell.UI.Universal.Views.SingleImageInformation.XButtonsMapping"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MaxWidth="1280" MaxHeight="720"
    mc:Ignorable="d">
    <UserControl.Background>
        <ImageBrush ImageSource="{DynamicResource ImageShellBlockingBackground}" Stretch="UniformToFill" />
    </UserControl.Background>

    <Grid>
        <!--Grid.Background>
            <ImageBrush ImageSource="{DynamicResource OverlayBackground}" />
        </-->

        <Image Grid.Row="0" Margin="50" Source="{DynamicResource ImageXbuttonsMapping}" />

    </Grid>
</UserControl>
