<UserControl
    x:Class="LeapVR.Shell.UI.Universal.Views.ApplicationThumbnail.Normal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Effect>
        <DropShadowEffect />
    </UserControl.Effect>
    <UserControl.Resources>
        <Style TargetType="Image">
            <Setter Property="MaxWidth" Value="552" />
            <Setter Property="MaxHeight" Value="258" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Image
            x:Name="Thumbnail"
            Grid.Row="0" Grid.Column="0"
            Source="{Binding Source, Mode=OneWay, FallbackValue={StaticResource ThumbnailAppNoPicture}, TargetNullValue={StaticResource ThumbnailAppNoPicture}}"
            Stretch="Fill">
            <Image.Effect>
                <DropShadowEffect BlurRadius="30" Direction="0" ShadowDepth="1" Color="Black" />
            </Image.Effect>
        </Image>

        <!--<Image>
            <Image.Source>
                <MultiBinding Converter="">
                    <Binding Path="IsScreenModeSupported" />
                    <Binding Path="IsVrModeSupported" />
                </MultiBinding>
            </Image.Source>
        </Image>-->

        <Image
            x:Name="ScreenModeOverlay"
            Grid.Row="0" Grid.Column="0"
            Source="{DynamicResource ImageScreenOverlay}"
            Stretch="Fill"
            Visibility="{Binding IsScreenModeSupported, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        <Image
            x:Name="VrModeOverlay"
            Grid.Row="0" Grid.Column="0"
            Source="{DynamicResource ImageVrOverlay}"
            Stretch="Fill"
            Visibility="{Binding IsVrModeSupported, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
    </Grid>
</UserControl>
