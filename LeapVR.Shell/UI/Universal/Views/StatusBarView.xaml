<UserControl
    x:Class="LeapVR.Shell.UI.Universal.Views.StatusBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    d:DesignHeight="80"
    d:DesignWidth="1920"
    mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource ImageBannerBg}" />
        </Grid.Background>
        <Grid Margin="20,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Image x:Name="Logo" Source="{DynamicResource BannerLeapvr}" />
            </StackPanel>


            <ContentControl
                Grid.Column="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                cal:View.Context="StationName"
                cal:View.Model="{Binding StationDetailsViewModel}"
                FontSize="{DynamicResource H5}"
                Foreground="{DynamicResource GuardViewsPrimaryForegroundColor}" />

            <StackPanel
                Grid.Column="2"
                FlowDirection="RightToLeft"
                Orientation="Horizontal">

                <ContentControl
                    x:Name="LanguageSelectViewModel"
                    Height="44"
                    Focusable="False" />

                <ContentControl
                    x:Name="ClockViewModel"
                    Margin="20,0"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    FontSize="{DynamicResource H6}"
                    Foreground="{DynamicResource GuardViewsPrimaryForegroundColor}" />

                <ContentControl x:Name="ConnectionIndicatorViewModel" Height="30" />

                <ContentControl
                    Height="30"
                    Margin="20,0"
                    cal:View.Context="StationModeIndicator"
                    cal:View.Model="{Binding StationDetailsViewModel}"
                    FontSize="{DynamicResource H6}"
                    Foreground="{DynamicResource GuardViewsPrimaryForegroundColor}" />

            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
