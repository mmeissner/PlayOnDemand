<Window
    x:Class="LeapVR.Shell.UI.Shell.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
    xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Shell" Title="LeapVR Shell"
    MinWidth="1024" MinHeight="768"
    d:DesignHeight="1080" d:DesignWidth="1920" lex:LocalizeDictionary.DesignCulture="en" lex:ResxLocalizationProvider.DefaultAssembly="LeapVR.Shell.Language"
    lex:ResxLocalizationProvider.DefaultDictionary="Resources" AllowsTransparency="True" Background="Transparent" FontFamily="Microsoft YaHei"
    MouseDown="Window_MouseDown" Topmost="False" WindowStartupLocation="CenterScreen" WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <Storyboard x:Key="TransmitToLoginView">
            <ThicknessAnimation
                BeginTime="0:0:0.2" DecelerationRatio="0.6"
                Storyboard.Target="{Binding ElementName=LoginViewModel}"
                Storyboard.TargetProperty="(Grid.Margin)" To="0,0,0,0" Duration="0:0:0.8" />
        </Storyboard>
        <Storyboard x:Key="TransmitToDashboardView">
            <ThicknessAnimation
                AccelerationRatio="0.6" BeginTime="0:0:0.7"
                Storyboard.Target="{Binding ElementName=LoginViewModel}"
                Storyboard.TargetProperty="(Grid.Margin)" To="0,-1920,0,1920" Duration="0:0:0.8" />
        </Storyboard>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{DynamicResource TransmitToLoginView}" />
        </EventTrigger>
    </Window.Triggers>
    <i:Interaction.Triggers>
        <ei:DataTrigger Binding="{Binding ActiveViewName}" Value="LoginViewModel">
            <ei:ControlStoryboardAction Storyboard="{StaticResource TransmitToLoginView}" />
        </ei:DataTrigger>
        <ei:DataTrigger Binding="{Binding ActiveViewName}" Value="DashboardViewModel">
            <ei:ControlStoryboardAction Storyboard="{StaticResource TransmitToDashboardView}" />
        </ei:DataTrigger>
    </i:Interaction.Triggers>

    <Grid x:Name="Root">
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource BackgroundGlobal}" Stretch="Fill" />
        </Grid.Background>

        <Grid
            x:Name="ShellBlockingContainer"
            Grid.Row="0"
            Panel.ZIndex="10"
            FocusManager.IsFocusScope="True" Focusable="True"
            Visibility="{Binding ShellBlockingViewModel.IsClosed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true, FallbackValue=Collapsed, TargetNullValue=Collapsed}">
            <!--Grid.Background>
                <ImageBrush ImageSource="{DynamicResource OverlayBackground}" />
            </-->

            <Grid.Resources>
                <Storyboard x:Key="DotRecycling">
                    <ObjectAnimationUsingKeyFrames RepeatBehavior="Forever" Storyboard.Target="{Binding ElementName=ShellBlockingViewModel.TextDotIncreasing}" Storyboard.TargetName="TextDotIncreasing" Storyboard.TargetProperty="(Run.Text)">
                        <ObjectAnimationUsingKeyFrames.KeyFrames>
                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="." />
                            <DiscreteObjectKeyFrame KeyTime="0:0:0.5" Value=".." />
                            <DiscreteObjectKeyFrame KeyTime="0:0:1" Value="..." />
                            <DiscreteObjectKeyFrame KeyTime="0:0:1.5" Value="...." />
                            <DiscreteObjectKeyFrame KeyTime="0:0:2" Value="....." />
                            <DiscreteObjectKeyFrame KeyTime="0:0:2.5" Value="......" />
                            <DiscreteObjectKeyFrame KeyTime="0:0:3" Value="......" />
                        </ObjectAnimationUsingKeyFrames.KeyFrames>
                    </ObjectAnimationUsingKeyFrames>
                </Storyboard>
            </Grid.Resources>

            <Rectangle Fill="Black" Opacity="0.6" />
            <Border Width="1000" Height="600" BorderBrush="{DynamicResource ThemeHighlightBackgroundColor}" BorderThickness="5">
                <Border.Background>
                    <ImageBrush ImageSource="{DynamicResource ImageShellBlockingBackground}" Stretch="UniformToFill" />
                </Border.Background>
                <Grid>
                    <!--Grid.Background>
                        <ImageBrush ImageSource="{DynamicResource OverlayBackground}" Stretch="UniformToFill" />
                    </-->
                    <ContentControl x:Name="ShellBlockingViewModel" />
                </Grid>
            </Border>
        </Grid>

        <ContentControl x:Name="AdministrationViewModel" Grid.Row="0" Panel.ZIndex="5" />

        <ContentControl x:Name="LoginViewModel" Grid.Row="0" Panel.ZIndex="3" />

        <ContentControl x:Name="DashboardViewModel" Grid.Row="0" Panel.ZIndex="1" />

    </Grid>
</Window>

