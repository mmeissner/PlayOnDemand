<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Connect.Views.ConnectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:LeapVR.Shell.UI.Shell.Connect.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    lex:LocalizeDictionary.DesignCulture="en-US"
    lex:ResxLocalizationProvider.DefaultAssembly="LeapVR.Shell.Language"
    lex:ResxLocalizationProvider.DefaultDictionary="Resources"
    BorderBrush="{DynamicResource ThemeBorderColor}"
    BorderThickness="3"
    mc:Ignorable="d">
    <UserControl.Background>
        <ImageBrush ImageSource="{DynamicResource ImageShellBlockingBackground}" />
    </UserControl.Background>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            Margin="5"
            Orientation="Vertical">
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,20,0"
                FontSize="{DynamicResource H4}"
                Style="{DynamicResource TextBlockBaseStyle}"
                Text="{lex:Loc Connect_LoginTitle}" />
            <Separator />
        </StackPanel>
        <Grid Margin="10" Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="8" />
                <RowDefinition Height="35" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,20,0"
                FontSize="{DynamicResource H5}"
                Style="{DynamicResource TextBlockBaseStyle}"
                Text="{lex:Loc Connect_StationId}" />
            <TextBox
                x:Name="StationId"
                Grid.Row="0"
                Grid.Column="1"
                MinWidth="370"
                FontSize="{DynamicResource H6}" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="0,0,20,0"
                FontSize="{DynamicResource H5}"
                Style="{DynamicResource TextBlockBaseStyle}"
                Text="{lex:Loc Connect_Password}" />
            <PasswordBox
                x:Name="Password"
                Grid.Row="2"
                Grid.Column="1"
                FontSize="{DynamicResource H6}" />
        </Grid>
        <StackPanel
            Grid.Row="2"
            Grid.Column="0"
            Margin="15"
            FlowDirection="LeftToRight"
            Orientation="Horizontal">
            <CheckBox
                Name="AutoLogin"
                Margin="35,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsThreeState="False" />
            <TextBlock
                FontSize="{DynamicResource H6}"
                Style="{DynamicResource TextBlockBaseStyle}"
                Text="{lex:Loc Connect_AutoLogin}" />
        </StackPanel>

        <UniformGrid Grid.Row="3" Columns="2">
            <usercontrols:LeapButton
                x:Name="ConnectAction"
                MinWidth="250"
                Margin="5"
                Padding="0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                Focusable="True"
                FontSize="{DynamicResource GuardViewsH5}"
                Style="{DynamicResource GuardViewsButtonStyle}"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true, FallbackValue=Visible}">

                <usercontrols:LeapButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="15,5,15,5"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource H4}"
                            Text="{lex:Loc Connect_Connect}" />
                    </StackPanel>
                </usercontrols:LeapButton.Content>
            </usercontrols:LeapButton>
            <usercontrols:LeapButton
                x:Name="DisconnectAction"
                MinWidth="250"
                Margin="5"
                Padding="0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                Focusable="True"
                FontSize="{DynamicResource GuardViewsH5}"
                Style="{DynamicResource GuardViewsButtonStyle}"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">

                <usercontrols:LeapButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="15,5,15,5"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource H4}"
                            Text="{lex:Loc Connect_Disconnect}" />
                    </StackPanel>
                </usercontrols:LeapButton.Content>
            </usercontrols:LeapButton>
            <usercontrols:LeapButton
                x:Name="CancelOrExit"
                MinWidth="250"
                Margin="5"
                Padding="0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                Focusable="True"
                FontSize="{DynamicResource GuardViewsH5}"
                Style="{DynamicResource GuardViewsButtonStyle}">

                <usercontrols:LeapButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="15,5,15,5"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource H4}"
                            Text="{lex:Loc Connect_Cancel}" />
                    </StackPanel>
                </usercontrols:LeapButton.Content>
            </usercontrols:LeapButton>
        </UniformGrid>
        <TextBlock
            Name="MessageText"
            Grid.Row="4"
            FontSize="{DynamicResource H6}"
            Style="{DynamicResource TextBlockBaseStyle}" />

    </Grid>
</UserControl>
