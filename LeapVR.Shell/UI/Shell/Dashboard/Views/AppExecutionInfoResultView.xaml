<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Dashboard.Views.AppExecutionInfoResultView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="LeapVR.Shell.UI.Shell.Dashboard.Views" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MinWidth="100" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
            x:Name="DisplayName"
            Grid.Column="0"
            Margin="0,0,0,-1"
            Background="Transparent"
            FontSize="{DynamicResource SessionViewsH4}"
            Style="{DynamicResource TextBlockBaseStyle}"
            TextAlignment="Left" />
        <UniformGrid
            Grid.Column="1"
            HorizontalAlignment="Right"
            Rows="1" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Hidden">
            <Image MaxWidth="50" Source="{DynamicResource IconGamepad}" Visibility="{Binding IsScreenModeSupported, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Image MaxWidth="50" Source="{DynamicResource IconHeadset}" Visibility="{Binding IsVirtualRealityRequired, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>
</UserControl>
