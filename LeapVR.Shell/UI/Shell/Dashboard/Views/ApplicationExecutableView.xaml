<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Dashboard.Views.ApplicationExecutableView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="AppExecutableRoot" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button x:Name="Execute" Grid.Row="0" Margin="0" Focusable="False">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="Transparent" BorderBrush="{TemplateBinding Background}" BorderThickness="3">
                                    <Grid>
                                        <Grid x:Name="PlayOverlay" Panel.ZIndex="1" Visibility="{Binding IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Rectangle x:Name="OverlayBg" Fill="Black" Opacity="0.4" />
                                            <Image x:Name="PlayImage" MaxWidth="{Binding ElementName=AppExecutableRoot, Path=ActualWidth, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.3}" Source="{DynamicResource IconPlay}" Stretch="Uniform" />
                                        </Grid>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!--<Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="PlayOverlay" Property="Visibility" Value="Visible" />
                                    </Trigger>-->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="PlayImage" Property="MaxWidth" Value="105" />
                                        <Setter TargetName="PlayImage" Property="MaxHeight" Value="105" />
                                        <Setter TargetName="OverlayBg" Property="Opacity" Value="0.6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>

            <Button.Content>
                <ContentControl x:Name="Thumbnail" VerticalAlignment="Top" cal:View.Context="Normal" />
            </Button.Content>
        </Button>

        <TextBlock
            Grid.Row="1"
            Width="{Binding ElementName=Execute, Path=ActualWidth}"
            Margin="0,9,0,0"
            Background="Transparent"
            FontSize="{DynamicResource SessionViewsH5}"
            Text="{Binding Name, Mode=OneWay}"
            TextAlignment="Center">
            <TextBlock.Style>
                <Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="{x:Type TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="true">
                            <Setter Property="FontWeight" Value="Bold" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActive}" Value="false">
                            <Setter Property="FontWeight" Value="Normal" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>

</UserControl>
