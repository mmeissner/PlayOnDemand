<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Dashboard.Views.AppExecutionSelectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:local="clr-namespace:LeapVR.Shell.UI.Shell.Dashboard.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    MinWidth="768" MinHeight="600"
    BorderBrush="{DynamicResource ThemeBorderColor}"
    BorderThickness="3"
    mc:Ignorable="d">
    <UserControl.Background>
        <ImageBrush ImageSource="{DynamicResource ImageShellBlockingBackground}" Stretch="UniformToFill" />
    </UserControl.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            FontSize="{DynamicResource SessionViewsH3}"
            Style="{DynamicResource TextBlockBaseStyle}"
            Text="{lex:Loc SelectAppExecutionResult}"
            TextAlignment="Center" />

        <ListBox
            x:Name="ExecutionCandidates"
            Grid.Row="1"
            Margin="25,25,25,15.403" HorizontalContentAlignment="Stretch"
            Background="Transparent" BorderBrush="Transparent"
            ItemContainerStyle="{DynamicResource AppExecutionInfoResultListBoxItemStyle}"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <ListBox.Resources>
                <Style x:Key="AppExecutionInfoResultListBoxItemStyle" TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="0,10" />
                </Style>
            </ListBox.Resources>
        </ListBox>

        <UniformGrid Grid.Row="2" Rows="1">
            <usercontrols:LeapButton
                x:Name="Confirm"
                Width="300" Height="70"
                Margin="20" HorizontalAlignment="Left" VerticalAlignment="Center"
                cal:Message.Attach="[Key Enter] = [Action Confirm()]" BorderThickness="1"
                FontSize="{DynamicResource GuardViewsH5}"
                Style="{DynamicResource GuardViewsButtonStyle}"
                Visibility="{Binding IsCancelOnly, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">

                <usercontrols:LeapButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,15,1" VerticalAlignment="Center" Text="{lex:Loc Global_Confirm}" />
                        <Image Width="{DynamicResource GuardViewsH4}" Source="{DynamicResource IconXboxControllerA}" Visibility="{Binding EnableGamepadIndicator, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                    </StackPanel>
                </usercontrols:LeapButton.Content>

            </usercontrols:LeapButton>

            <usercontrols:LeapButton
                x:Name="Cancel"
                Width="300" Height="70"
                Margin="20" HorizontalAlignment="Right" VerticalAlignment="Center"
                BorderThickness="1"
                FontSize="{DynamicResource GuardViewsH5}"
                Style="{DynamicResource GuardViewsButtonStyle}">
                <usercontrols:LeapButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,15,1" VerticalAlignment="Center" Text="{lex:Loc Global_Cancel}" />
                        <Image Width="{DynamicResource GuardViewsH4}" Source="{DynamicResource IconXboxControllerB}" Visibility="{Binding EnableGamepadIndicator, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                    </StackPanel>
                </usercontrols:LeapButton.Content>
            </usercontrols:LeapButton>

        </UniformGrid>



    </Grid>
</UserControl>
