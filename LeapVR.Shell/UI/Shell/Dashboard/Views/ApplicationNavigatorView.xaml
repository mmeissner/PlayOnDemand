<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Dashboard.Views.ApplicationNavigatorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:LeapVR.Shell.UI.Core.Behaviors" xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:tz="http://schemas.abtsoftware.co.uk/transitionz" xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    d:DesignHeight="750" d:DesignWidth="1920"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="100" />
        </Grid.ColumnDefinitions>

        <usercontrols:LeapButton
            x:Name="NavigateToPreviousPage"
            Grid.Column="0"
            BorderBrush="Transparent" BorderRadius="0" BorderThickness="0" Focusable="False"
            Style="{DynamicResource SessionViewsButtonStyle}">
            <usercontrols:LeapButton.Background>
                <ImageBrush ImageSource="{DynamicResource ImageScrollLeft}" Stretch="Uniform" />
            </usercontrols:LeapButton.Background>
            <usercontrols:LeapButton.HoverBackground>
                <ImageBrush ImageSource="{DynamicResource ImageScrollLeftHover}" Stretch="Uniform" />
            </usercontrols:LeapButton.HoverBackground>
            <usercontrols:LeapButton.PressedBackground>
                <ImageBrush ImageSource="{DynamicResource ImageScrollLeftPressed}" Stretch="Uniform" />
            </usercontrols:LeapButton.PressedBackground>

        </usercontrols:LeapButton>

        <usercontrols:LeapButton
            x:Name="NavigateToNextPage"
            Grid.Column="2"
            BorderBrush="Transparent" BorderRadius="0" BorderThickness="0" Focusable="False"
            HoverBorderBrush="Transparent"
            Style="{DynamicResource SessionViewsButtonStyle}">
            <usercontrols:LeapButton.Background>
                <ImageBrush ImageSource="{DynamicResource ImageScrollRight}" Stretch="Uniform" />
            </usercontrols:LeapButton.Background>
            <usercontrols:LeapButton.HoverBackground>
                <ImageBrush ImageSource="{DynamicResource ImageScrollRightHover}" Stretch="Uniform" />
            </usercontrols:LeapButton.HoverBackground>
            <usercontrols:LeapButton.PressedBackground>
                <ImageBrush ImageSource="{DynamicResource ImageScrollRightPressed}" Stretch="Uniform" />
            </usercontrols:LeapButton.PressedBackground>
        </usercontrols:LeapButton>

        <ListBox
            x:Name="Items"
            Grid.Column="1"
            cal:Message.Attach="[Key Enter] = [Action ExecuteSelectedItem()]"
            Background="{DynamicResource SessionViewsPrimaryBackgroundColor}"
            BorderThickness="0"
            ItemContainerStyle="{DynamicResource ApplicationExecutableContainerStyle}"
            KeyboardNavigation.DirectionalNavigation="Cycle" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <i:Interaction.Behaviors>
                <behaviors:ItemsControlExternalNavigationBehavior ScrollLeftButton="{Binding ElementName=NavigateToPreviousPage}" ScrollRightButton="{Binding ElementName=NavigateToNextPage}" />
            </i:Interaction.Behaviors>

            <ListBox.Resources>
                <Style x:Key="ApplicationExecutableContainerStyle" TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Foreground" Value="Transparent" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="MaxWidth" Value="{Binding ElementName=Items, Path=ActualWidth, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.332942}" />
                    <Setter Property="MaxHeight" Value="{Binding ElementName=Items, Path=ActualHeight, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.5}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Margin" Value="0,0" />
                    <Setter Property="Padding" Value="10,5" />
                    <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis" />
                    <Setter Property="UseLayoutRounding" Value="False" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template" Value="{DynamicResource ApplicationExecutableContainerTemplate}" />
                </Style>

                <ControlTemplate x:Key="ApplicationExecutableContainerTemplate" TargetType="{x:Type ListBoxItem}">
                    <Border
                        x:Name="Border"
                        Margin="{TemplateBinding Margin}"
                        Padding="{TemplateBinding Padding}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        cal:Message.Attach="[Event MouseEnter] = [Action SelectItem($dataContext)]"
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter x:Name="ContentSite" TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="false" />
                                <Condition Property="IsFocused" Value="false" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="Transparent" />
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="true" />
                                <Condition Property="IsFocused" Value="false" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource ThemeItemActiveBackgroundColor}" />
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="true" />
                                <Condition Property="IsFocused" Value="true" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource ThemeItemActiveBackgroundColor}" />
                        </MultiTrigger>
                        <EventTrigger RoutedEvent="ListBoxItem.Selected">
                            <EventTrigger.Actions>
                                <SoundPlayerAction Source="pack://application:,,,/LeapPlay.Shell;component/Resources/ButtonClick.wav" />
                            </EventTrigger.Actions>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </ListBox.Resources>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid
                        HorizontalAlignment="Left"
                        Background="Transparent" IsItemsHost="True" KeyboardNavigation.TabIndex="1" Rows="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

        </ListBox>

    </Grid>
</UserControl>
