<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Dashboard.Views.SessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="100"
    d:DesignWidth="1280"
    mc:Ignorable="d">
    <Grid x:Name="PanelSessionInfo">
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="{x:Type ColumnDefinition}">
                        <Setter Property="Width" Value="Auto" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PaymentVisible}" Value="True">
                                <Setter Property="Width" Value="1*" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*" />
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="{x:Type ColumnDefinition}">
                        <Setter Property="Width" Value="Auto" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PaymentVisible}" Value="True">
                                <Setter Property="Width" Value="1*" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="{x:Type ColumnDefinition}">
                        <Setter Property="Width" Value="Auto" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PaymentVisible}" Value="True">
                                <Setter Property="Width" Value="1*" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
        </Grid.ColumnDefinitions>
        <!--DockPanel
            x:Name="SessionRateDisplay"
            Grid.Column="0"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Visibility="{Binding PaymentVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <fa:FontAwesome Margin="15,0" FontSize="{DynamicResource SessionViewsH1}" Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}" Icon="Money" />
            <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource SessionViewsH6}" Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}" TextAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{Binding Rate, Mode=OneWay}" />
                </TextBlock.Inlines>
            </TextBlock>
        </-->

        <DockPanel
            x:Name="SessionPlayedDisplay"
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <fa:FontAwesome
                Margin="15,0"
                FontSize="{DynamicResource SessionViewsH1}"
                Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}"
                Icon="ClockOutline" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="{DynamicResource SessionViewsH6}"
                Foreground="{DynamicResource SessionViewsDisabledForegroundColor}"
                TextAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc Global_Session_YouPlayed}" />
                    <LineBreak />
                    <Run Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}" Text="{Binding Played, StringFormat=h\\:mm\\:ss}" />
                </TextBlock.Inlines>
            </TextBlock>
        </DockPanel>

        <DockPanel
            x:Name="SessionTimeRemainingDisplay"
            Grid.Column="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding PaymentVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <fa:FontAwesome
                Margin="15,0"
                FontSize="{DynamicResource SessionViewsH2}"
                Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}"
                Icon="HourglassStart" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="{DynamicResource SessionViewsH6}"
                Foreground="{DynamicResource SessionViewsDisabledForegroundColor}"
                TextAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc Session_TimeRemaining}" />
                    <LineBreak />
                    <Run Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}" Text="{Binding TimeRemaining, StringFormat=h\\:mm\\:ss}" />
                </TextBlock.Inlines>
            </TextBlock>
        </DockPanel>

        <!--DockPanel
            x:Name="SessionBalanceDisplay"
            Grid.Column="3"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Visibility="{Binding PaymentVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <fa:FontAwesome Margin="15,0" FontSize="{DynamicResource SessionViewsH2}" Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}" Icon="CreditCard" />
            <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource SessionViewsH6}" Foreground="{DynamicResource SessionViewsDisabledForegroundColor}" TextAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc Global_Session_YourBalance}" />
                    <LineBreak />
                    <Run Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}" Text="{Binding BalanceString, Mode=OneWay}" />
                    <Run Text="{lex:Loc Session_CurrencyUnit}" />
                </TextBlock.Inlines>
            </TextBlock>
        </-->
    </Grid>
</UserControl>

