<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Dashboard.Views.CategoryHeaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:LeapVR.Shell.UI.Shell.Dashboard.Views" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="150" d:DesignWidth="300"
    mc:Ignorable="d">
    <StackPanel x:Name="TabContent" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
        <Image
            Width="{DynamicResource SessionViewsTabButtonFontSize}"
            Height="{DynamicResource SessionViewsTabButtonFontSize}"
            Margin="10,0"
            Source="{Binding AppCategory.Icon, Mode=OneWay}"
            Stretch="Uniform" />
        <TextBlock
            x:Name="ContentSite"
            Margin="5"
            FontSize="{DynamicResource SessionViewsH5}"
            Foreground="{DynamicResource SessionViewsPrimaryForegroundColor}"
            Text="{Binding AppCategory.DisplayName, Mode=OneWay}" />
    </StackPanel>
</UserControl>
