<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Updates.Views.UpdateDownloadingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:local="clr-namespace:LeapVR.Shell.UI.Shell.SystemAdministration.Updates.Views" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="720" d:DesignWidth="1280"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="15" Style="{DynamicResource TextBlockBaseStyle}" TextAlignment="Center">
            <TextBlock.Inlines>
                <Run FontSize="{DynamicResource H4}" Text="{lex:Loc System_Updates_Announcement_Downloading}" />
            </TextBlock.Inlines>
        </TextBlock>
        <StackPanel Grid.Row="1" Margin="50,0" VerticalAlignment="Center">
            <Grid>
                <ProgressBar Height="80" Margin="20" Value="{Binding DownloadProgressPercent, Mode=OneWay}" />
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource H3}" Text="{Binding DownloadProgress, Mode=OneWay}" />
            </Grid>
            <TextBlock VerticalAlignment="Top" FontSize="{DynamicResource H3}" Foreground="{DynamicResource ThemeMainTextColor}" TextAlignment="Right">
                <TextBlock.Inlines>
                    <Run Text="{Binding DownloadSpeed, Mode=OneWay, FallbackValue=123456}" />
                </TextBlock.Inlines>
            </TextBlock>
        </StackPanel>
        <Button
            x:Name="Cancel"
            Grid.Row="2"
            Width="500" Height="80"
            BorderThickness="3"
            Content="{lex:Loc Global_Cancel}"
            FontSize="{DynamicResource H3}"
            Style="{DynamicResource ButtonBaseStyle}" />

    </Grid>
</UserControl>
