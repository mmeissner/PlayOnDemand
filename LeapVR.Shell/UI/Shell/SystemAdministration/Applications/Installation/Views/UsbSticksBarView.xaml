<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Applications.Installation.Views.UsbSticksBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:properties="clr-namespace:LeapVR.Shell.Properties"
    d:DesignHeight="100" d:DesignWidth="600"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <ItemsPanelTemplate x:Key="ItemsPanelTemplate">
            <VirtualizingStackPanel IsItemsHost="True" Orientation="Horizontal" />
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid>

        <i:Interaction.Triggers>
            <ei:DataTrigger Binding="{Binding LoadingState}" Value="Nothing">
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=NoDataView}" TargetName="NoDataView" Value="Visible" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=LoadingView}" TargetName="LoadingView" Value="Collapsed" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=Spinner}" TargetName="Spinner" Value="Collapsed" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=Items}" TargetName="Items" Value="Collapsed" />
            </ei:DataTrigger>

            <ei:DataTrigger Binding="{Binding LoadingState}" Value="Loading">
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=NoDataView}" TargetName="NoDataView" Value="Collapsed" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=LoadingView}" TargetName="LoadingView" Value="Visible" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=Spinner}" TargetName="Spinner" Value="Visible" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=Items}" TargetName="Items" Value="Collapsed" />
            </ei:DataTrigger>

            <ei:DataTrigger Binding="{Binding LoadingState}" Value="Loaded">
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=NoDataView}" TargetName="NoDataView" Value="Collapsed" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=LoadingView}" TargetName="LoadingView" Value="Collapsed" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=Spinner}" TargetName="Spinner" Value="Collapsed" />
                <ei:ChangePropertyAction PropertyName="Visibility" TargetObject="{Binding ElementName=Items}" TargetName="Items" Value="Visible" />
            </ei:DataTrigger>
        </i:Interaction.Triggers>

        <DockPanel x:Name="NoDataView" HorizontalAlignment="Center">
            <Image Margin="20" Source="{DynamicResource IconUsbDrivePhysical}" />
            <TextBlock Margin="10" FontSize="{DynamicResource H3}" Text="{lex:Loc System_Installation_NoUsbDrive}" />
        </DockPanel>

        <DockPanel x:Name="LoadingView" HorizontalAlignment="Center" VerticalAlignment="Center">
            <UserControl x:Name="Spinner" Width="40" Template="{DynamicResource AppleSpinner}" />
            <TextBlock Margin="5,0,5,0" FontSize="{DynamicResource H5}" Text="{lex:Loc Global_Loading}" />
        </DockPanel>

        <ListView
            x:Name="Items"
            HorizontalAlignment="Center"
            Background="Transparent" BorderThickness="0"
            ItemContainerStyle="{DynamicResource ListViewItemForUsbStick}"
            ItemsPanel="{DynamicResource ItemsPanelTemplate}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Hidden" />
    </Grid>
</UserControl>

