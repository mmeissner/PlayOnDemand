<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Applications.Installation.Views.UninstallationAppView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalContentAlignment="Stretch"
    d:DesignHeight="100" d:DesignWidth="600"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource H5}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="40" />
        </Grid.ColumnDefinitions>
        <ContentControl
            x:Name="Thumbnail"
            Grid.Row="0" Grid.Column="0"
            Width="92" Height="43"
            Margin="5"
            cal:View.Context="Small" />
        <TextBlock
            x:Name="Title"
            Grid.Row="0" Grid.Column="1"
            Margin="5,0,5,0" HorizontalAlignment="Stretch"
            Text="{Binding Name, FallbackValue='Application Name'}"
            TextTrimming="CharacterEllipsis" />
        <Image Grid.Column="3" Width="30" Height="30" Source="{Binding HealthIcon, Mode=OneWay}" />
        <TextBlock
            x:Name="FileSize"
            Grid.Row="0" Grid.Column="2"
            Margin="5,0,5,0" HorizontalAlignment="Stretch"
            Text="{Binding OccupiedSpaceSize, Converter={StaticResource BytesToProperSpaceUnitConverter}}"
            TextAlignment="Right" />
    </Grid>

</UserControl>
