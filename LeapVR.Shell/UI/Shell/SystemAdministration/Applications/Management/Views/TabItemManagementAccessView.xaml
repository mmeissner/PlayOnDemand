<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Applications.Management.Views.TabItemManagementAccessView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    d:DesignHeight="720" d:DesignWidth="1280"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition MinWidth="300" MaxWidth="500" />
        </Grid.ColumnDefinitions>

        <TextBlock
            x:Name="NoApplicationsView"
            VerticalAlignment="Center"
            FontSize="{DynamicResource H1}"
            Foreground="White"
            Text="{lex:Loc System_Installation_NoApplications}"
            TextAlignment="Center"
            Visibility="{Binding IsZeroItems, Converter={StaticResource BoolToVisibilityConverter}}" />

        <ItemsControl
            x:Name="Items"
            Grid.Column="0"
            Margin="25" HorizontalContentAlignment="Stretch"
            ItemContainerStyle="{DynamicResource ItemsItemUniversalStyle}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
            Style="{DynamicResource ItemsControlStyleWithoutColumns}"
            VirtualizingPanel.ScrollUnit="Pixel" />

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="{DynamicResource H3}" Style="{DynamicResource TextBlockBaseStyle}">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc Global_Categories}" />
                    <Span>:</Span>
                </TextBlock.Inlines>
            </TextBlock>
            <ListView
                x:Name="Categories"
                Grid.Row="1"
                Margin="25" HorizontalContentAlignment="Stretch"
                cal:Message.Attach="[Event SelectionChanged] = [Action OnActivatedCategoriesChanged($eventArgs)]" BorderBrush="Transparent"
                FontSize="{DynamicResource H3}"
                ItemContainerStyle="{DynamicResource ListViewItemForTag}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionMode="Multiple"
                Style="{StaticResource ListViewStyleBase}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Margin="20,10,20,10" FontSize="{DynamicResource H4}" Style="{DynamicResource TextBlockBaseStyle}" Text="{Binding DisplayName, Mode=OneWay}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

    </Grid>
</UserControl>
