<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Applications.Management.Edit.Views.AdvanceEditAppView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:LeapVR.Shell.UI.Shell.SystemAdministration.Applications.Management.Edit.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    d:DesignHeight="450"
    d:DesignWidth="800"
    lex:LocalizeDictionary.DesignCulture="en-US"
    lex:ResxLocalizationProvider.DefaultAssembly="LeapVR.Shell.Language"
    lex:ResxLocalizationProvider.DefaultDictionary="Resources"
    BorderBrush="{DynamicResource ThemeBorderColor}"
    BorderThickness="3"
    mc:Ignorable="d">
    <UserControl.Background>
        <ImageBrush ImageSource="{DynamicResource ImageShellBlockingBackground}" />
    </UserControl.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <GroupBox
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="15"
            FontSize="{DynamicResource H4}">
            <GroupBox.Header>
                <TextBlock
                    FontSize="{DynamicResource H4}"
                    Style="{StaticResource TextBlockBaseStyle}"
                    Text="{lex:Loc System_Application_Advance_Edit_Execution_Instruction}" />
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <usercontrols:LeapButton
                    x:Name="AddExecutionInstruction"
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="15"
                    Padding="80,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderThickness="1"
                    Focusable="True"
                    FontSize="{DynamicResource GuardViewsH5}"
                    Style="{DynamicResource GuardViewsButtonStyle}">
                    <usercontrols:LeapButton.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,15,0"
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource H5}"
                                Text="{lex:Loc System_Application_Advance_Edit_Add}" />
                        </StackPanel>
                    </usercontrols:LeapButton.Content>
                </usercontrols:LeapButton>
                <usercontrols:LeapButton
                    x:Name="EditExecutionInstruction"
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="15"
                    Padding="80,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderThickness="1"
                    Focusable="True"
                    FontSize="{DynamicResource GuardViewsH5}"
                    Style="{DynamicResource GuardViewsButtonStyle}">
                    <usercontrols:LeapButton.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,15,0"
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource H5}"
                                Text="{lex:Loc System_Application_Advance_Edit_Edit}" />
                        </StackPanel>
                    </usercontrols:LeapButton.Content>
                </usercontrols:LeapButton>
                <usercontrols:LeapButton
                    x:Name="RemoveExecutionInstruction"
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="15"
                    Padding="80,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderThickness="1"
                    Focusable="True"
                    FontSize="{DynamicResource GuardViewsH5}"
                    Style="{DynamicResource GuardViewsButtonStyle}">
                    <usercontrols:LeapButton.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,15,0"
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource H5}"
                                Text="{lex:Loc System_Application_Advance_Edit_Remove}" />
                        </StackPanel>
                    </usercontrols:LeapButton.Content>
                </usercontrols:LeapButton>
                <ListView
                    Name="ExecutionInstructions"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource ListViewStyleBase}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                FontSize="{DynamicResource H4}"
                                Style="{StaticResource TextBlockBaseStyle}"
                                Text="{Binding Path=DisplayName}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </GroupBox>
        <usercontrols:LeapButton
            x:Name="Apply"
            Grid.Row="1"
            Grid.Column="0"
            Margin="15"
            Padding="100,5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderThickness="1"
            Focusable="True"
            FontSize="{DynamicResource GuardViewsH5}"
            Style="{DynamicResource GuardViewsButtonStyle}">
            <usercontrols:LeapButton.Content>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,15,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource H4}"
                        Text="{lex:Loc System_Application_Advance_Edit_Apply}" />
                </StackPanel>
            </usercontrols:LeapButton.Content>
        </usercontrols:LeapButton>
        <usercontrols:LeapButton
            x:Name="Cancel"
            Grid.Row="1"
            Grid.Column="2"
            Margin="15"
            Padding="100,5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderThickness="1"
            Focusable="True"
            FontSize="{DynamicResource GuardViewsH5}"
            Style="{DynamicResource GuardViewsButtonStyle}">
            <usercontrols:LeapButton.Content>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,15,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource H4}"
                        Text="{lex:Loc System_Application_Advance_Edit_Cancel}" />
                </StackPanel>
            </usercontrols:LeapButton.Content>
        </usercontrols:LeapButton>
    </Grid>
</UserControl>