<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Applications.Management.Edit.Views.AdvancedEditExecutionInstructionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:LeapVR.Shell.UI.Shell.SystemAdministration.Applications.Management.Edit.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    d:DesignHeight="800"
    d:DesignWidth="1280"
    lex:LocalizeDictionary.DesignCulture="en-US"
    lex:ResxLocalizationProvider.DefaultAssembly="LeapVR.Shell.Language"
    lex:ResxLocalizationProvider.DefaultDictionary="Resources"
    BorderBrush="{DynamicResource ThemeBorderColor}"
    BorderThickness="3"
    mc:Ignorable="d">
    <UserControl.Background>
        <ImageBrush ImageSource="{DynamicResource ImageShellBlockingBackground}" />
    </UserControl.Background>
    <UserControl.Resources>
        <DataTemplate x:Key="InfoTemplate">
            <Grid>
                <fa:FontAwesome
                    x:Name="Help"
                    Background="Transparent"
                    Foreground="White"
                    Icon="QuestionCircle" />
                <Popup
                    AllowsTransparency="True"
                    HorizontalOffset="-190"
                    IsOpen="{Binding ElementName=Help, Path=IsMouseOver, Mode=OneWay}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=icon}"
                    PopupAnimation="Slide"
                    StaysOpen="True"
                    VerticalOffset="5">
                    <Border Background="#D6D6D6">
                        <TextBlock
                            Width="180"
                            Margin="10"
                            FontSize="{DynamicResource Paragraph}"
                            Foreground="Black"
                            Text="{Binding}"
                            TextAlignment="Left"
                            TextWrapping="WrapWithOverflow" />
                    </Border>
                </Popup>
            </Grid>


        </DataTemplate>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Margin="5"
            HorizontalAlignment="Left"
            FontSize="{DynamicResource H6}"
            Style="{StaticResource TextBlockBaseStyle}">

            <TextBlock.Inlines>
                <Run BaselineAlignment="Center" Text="{lex:Loc System_Application_Advance_Edit_ExeName}" />
                <ContentControl Content="{lex:Loc System_Application_Advance_Edit_Info_ExeName}" ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span BaselineAlignment="Center">:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="InstructionName"
            Grid.Row="3"
            Grid.Column="1"
            Margin="5"
            VerticalContentAlignment="Center"
            FontSize="{DynamicResource H6}"
            Foreground="{DynamicResource ThemeSecondaryTextColor}"
            TextAlignment="Left" />
        <usercontrols:LeapButton
            x:Name="NameFromExecutable"
            Grid.Row="3"
            Grid.Column="2"
            Margin="5"
            Style="{DynamicResource GuardViewsButtonStyle}">
            <usercontrols:LeapButton.Content>
                <TextBlock FontSize="{DynamicResource H6}" Text="{lex:Loc System_Application_Advance_Edit_SetFromExecutable}" />
            </usercontrols:LeapButton.Content>
        </usercontrols:LeapButton>
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Margin="5"
            HorizontalAlignment="Left"
            FontSize="{DynamicResource H6}"
            Style="{StaticResource TextBlockBaseStyle}">
            <TextBlock.Inlines>
                <Run BaselineAlignment="Center" Text="{lex:Loc System_Application_Advance_Edit_ApplicationMainExecutablePath}" />
                <ContentControl
                    VerticalContentAlignment="Center"
                    Content="{lex:Loc System_Application_Advance_Edit_Info_MainExePath}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span BaselineAlignment="Center">:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="ApplicationMainExecutablePath"
            Grid.Row="0"
            Grid.Column="1"
            Margin="5"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            FontSize="{DynamicResource H6}"
            IsEnabled="False"
            IsReadOnly="True"
            TextAlignment="Left" />
        <usercontrols:LeapButton
            x:Name="BrowseApplicationStartingProcessExecutablePath"
            Grid.Row="0"
            Grid.Column="2"
            Margin="5"
            Style="{DynamicResource GuardViewsButtonStyle}">
            <usercontrols:LeapButton.Content>
                <TextBlock FontSize="{DynamicResource H6}" Text="{lex:Loc System_Application_Advance_Edit_ExecutableInfo_SelectExecutable}" />
            </usercontrols:LeapButton.Content>
        </usercontrols:LeapButton>
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Margin="5"
            HorizontalAlignment="Left"
            FontSize="{DynamicResource H6}"
            Style="{StaticResource TextBlockBaseStyle}">
            <TextBlock.Inlines>
                <Run BaselineAlignment="Center" Text="{lex:Loc System_Application_Advance_Edit_WorkingDirectory}" />
                <ContentControl
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Content="{lex:Loc System_Application_Advance_Edit_Info_WorkingDirectory}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span BaselineAlignment="Center">:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="ApplicationMainExecutableWorkingDirectory"
            Grid.Row="1"
            Grid.Column="1"
            Margin="5"
            VerticalContentAlignment="Center"
            FontSize="{DynamicResource H6}"
            IsEnabled="False"
            IsReadOnly="True"
            TextAlignment="Left" />
        <usercontrols:LeapButton
            x:Name="BrowseWorkingDirectoryFolder"
            Grid.Row="1"
            Grid.Column="2"
            Margin="5"
            Style="{DynamicResource GuardViewsButtonStyle}">
            <usercontrols:LeapButton.Content>
                <TextBlock FontSize="{DynamicResource H6}" Text="{lex:Loc System_Application_Advance_Edit_ExecutableInfo_SelectFolder}" />
            </usercontrols:LeapButton.Content>
        </usercontrols:LeapButton>
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Margin="5"
            HorizontalAlignment="Left"
            FontSize="{DynamicResource H6}"
            Style="{StaticResource TextBlockBaseStyle}">
            <TextBlock.Inlines>
                <Run BaselineAlignment="Center" Text="{lex:Loc System_Application_Advance_Edit_ExecutableParameters}" />
                <ContentControl
                    VerticalContentAlignment="Center"
                    Content="{lex:Loc System_Application_Advance_Edit_Info_ExeParameters}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span BaselineAlignment="Center">:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="ApplicationMainExecutableParameters"
            Grid.Row="2"
            Grid.Column="1"
            Margin="5"
            VerticalContentAlignment="Center"
            FontSize="{DynamicResource H6}"
            TextAlignment="Left" />
        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            Margin="5"
            HorizontalAlignment="Left"
            FontSize="{DynamicResource H6}"
            Style="{StaticResource TextBlockBaseStyle}">
            <TextBlock.Inlines>
                <Run BaselineAlignment="Center" Text="{lex:Loc System_Application_Advance_Edit_RequiredVrModule}" />
                <ContentControl
                    VerticalContentAlignment="Center"
                    Content="{lex:Loc System_Application_Advance_Edit_Info_RequiredVrModule}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span BaselineAlignment="Center">:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <ComboBox
            Name="RequiredVrModules"
            Grid.Row="4"
            Grid.Column="1"
            Margin="5"
            VerticalContentAlignment="Center"
            DisplayMemberPath="DisplayName"
            FontSize="{DynamicResource H6}" />
        <GroupBox
            Grid.Row="5"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            FontSize="16">
            <GroupBox.Header>
                <TextBlock Style="{StaticResource TextBlockBaseStyle}" Text="{lex:Loc System_Application_Advance_Edit_WatchDogOptions}" />
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" MinWidth="310" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="{DynamicResource H5}"
                    Style="{StaticResource TextBlockBaseStyle}"
                    Text="{lex:Loc System_Application_Advance_Edit_ProcessMonitoring}"
                    TextAlignment="Center" />
                <Grid
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <usercontrols:LeapButton
                        x:Name="AddExecutable"
                        Grid.Column="0"
                        Margin="5"
                        Style="{DynamicResource GuardViewsButtonStyle}">
                        <usercontrols:LeapButton.Content>
                            <TextBlock FontSize="{DynamicResource H6}" Text="{lex:Loc System_Application_Advance_Edit_Add}" />
                        </usercontrols:LeapButton.Content>
                    </usercontrols:LeapButton>
                    <usercontrols:LeapButton
                        x:Name="RemoveExecutable"
                        Grid.Column="1"
                        Margin="5"
                        Style="{DynamicResource GuardViewsButtonStyle}">
                        <usercontrols:LeapButton.Content>
                            <TextBlock FontSize="{DynamicResource H6}" Text="{lex:Loc System_Application_Advance_Edit_Remove}" />
                        </usercontrols:LeapButton.Content>
                    </usercontrols:LeapButton>
                </Grid>
                <GroupBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5">
                    <GroupBox.Header>
                        <TextBlock Style="{StaticResource TextBlockBaseStyle}" Text="{lex:Loc System_Application_Advance_Edit_Options}" />
                    </GroupBox.Header>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="5"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource H6}"
                            Style="{StaticResource TextBlockBaseStyle}"
                            TextAlignment="Left">
                            <TextBlock.Inlines>
                                <Run Text="{lex:Loc System_Application_Advance_Edit_IsMainExe}" />
                                <ContentControl
                                    VerticalContentAlignment="Center"
                                    Content="{lex:Loc System_Application_Advance_Edit_Info_IsMainExe}"
                                    ContentTemplate="{DynamicResource InfoTemplate}" />
                            </TextBlock.Inlines>

                        </TextBlock>
                        <CheckBox
                            Name="IsMainExecutable"
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsChecked="{Binding Path=SelectedExecutable.IsMainExecutable}"
                            IsThreeState="False" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="5"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource H6}"
                            Style="{StaticResource TextBlockBaseStyle}"
                            TextAlignment="Left">
                            <TextBlock.Inlines>
                                <Run Text="{lex:Loc System_Application_Advance_Edit_KillOnExit}" />
                                <ContentControl
                                    VerticalContentAlignment="Center"
                                    Content="{lex:Loc System_Application_Advance_Edit_Info_KillOnExit}"
                                    ContentTemplate="{DynamicResource InfoTemplate}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <CheckBox
                            Name="KillOnExit"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsChecked="{Binding Path=SelectedExecutable.KillOnExit}"
                            IsEnabled="{Binding ElementName=IsMainExecutable, Path=IsChecked, Converter={StaticResource InvertBoolConverter}}"
                            IsThreeState="False" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="5"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource H6}"
                            Style="{StaticResource TextBlockBaseStyle}"
                            TextAlignment="Left">
                            <TextBlock.Inlines>
                                <Run Text="{lex:Loc System_Application_Advance_Edit_KillNotResponding}" />
                                <ContentControl
                                    VerticalContentAlignment="Center"
                                    Content="{lex:Loc System_Application_Advance_Edit_Info_KillNotResponding}"
                                    ContentTemplate="{DynamicResource InfoTemplate}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <CheckBox
                            Name="KillProcessOnNotResponding"
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsChecked="{Binding Path=SelectedExecutable.KillProcessOnNotResponding}"
                            IsEnabled="{Binding ElementName=IsMainExecutable, Path=IsChecked}"
                            IsThreeState="False" />
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Row="1" Grid.Column="0">
                    <GroupBox.Header>
                        <TextBlock Style="{StaticResource TextBlockBaseStyle}" Text="{lex:Loc System_Application_Advance_Edit_Executables}" />
                    </GroupBox.Header>
                    <ListView Name="Executables" Style="{StaticResource ListViewStyleBase}">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=ExecutableName}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </GroupBox>
            </Grid>
        </GroupBox>
        <Grid
            Grid.Row="6"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <usercontrols:LeapButton
                x:Name="Ok"
                Grid.Column="0"
                Margin="5"
                Content="{lex:Loc System_Application_Advance_Edit_Ok}"
                FontSize="{DynamicResource H4}"
                Style="{DynamicResource GuardViewsButtonStyle}" />
            <usercontrols:LeapButton
                x:Name="Cancel"
                Grid.Column="1"
                Margin="5"
                Content="{lex:Loc System_Application_Advance_Edit_Cancel}"
                FontSize="{DynamicResource H4}"
                Style="{DynamicResource GuardViewsButtonStyle}"
                Visibility="{Binding CancelButtonVisibility}" />
        </Grid>
    </Grid>
</UserControl>