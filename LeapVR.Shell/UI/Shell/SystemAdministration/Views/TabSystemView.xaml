<UserControl x:Class="LeapVR.Shell.UI.VrDashboard.SystemAdministration.Views.TabSystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions"
             xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">
    <Grid>
        <TabControl Name="Items" Grid.Row="0" 
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Height="Auto" Background="Transparent" BorderThickness="0"
                    Visibility="{Binding IsSystemLocked,Mode=OneWay,Converter={StaticResource BoolToVisibilityConverter},ConverterParameter=true,FallbackValue=Visible}"
                    ItemContainerStyle="{DynamicResource TabItemStyleVerticalLevel1}"
                    TabStripPlacement="Left" Margin="0, 0, 0, 0" />

        <Grid x:Name="PanelKeyPad" Grid.Row="0" 
              Visibility="{Binding IsSystemLocked,Mode=OneWay,Converter={StaticResource BoolToVisibilityConverter}}"
              >
            <Grid.RowDefinitions>
                <RowDefinition Height="150"></RowDefinition>
                <RowDefinition Height="150"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock 
                x:Name="InstructionMessage" DockPanel.Dock="Top" Margin="0,20" 
                FontSize="{DynamicResource H3}" Style="{DynamicResource TextBlockBaseStyle}" TextAlignment="Center"
                Text="{lex:Loc System_EnterPin}"/>
            <UniformGrid x:Name="PanelLanguage" Grid.Row="1" Rows="1" FirstColumn="1" Columns="4" Visibility="Visible" DockPanel.Dock="Top" >
                <RadioButton
                    x:Name="Chinese"  GroupName="Language" Focusable="False"
                    Width="300" Height="100" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Style="{DynamicResource RadioButtonBaseStyle}" 
                    IsChecked="{Binding CurrentCultureName,Mode=OneWay,
                    Converter={StaticResource CultureMatchToBoolConverter},ConverterParameter='zh-CN'}"
                    Content="简体中文" 
                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="{DynamicResource H2}"
                >
                </RadioButton>

                <RadioButton 
                    x:Name="English" GroupName="Language" Focusable="False"
                    Width="300" Height="100"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Style="{DynamicResource RadioButtonBaseStyle}" 
                    IsChecked="{Binding CurrentCultureName,Mode=OneWay,
                    Converter={StaticResource CultureMatchToBoolConverter},ConverterParameter='en-US'}"
                    Content="English" 
                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="{DynamicResource H2}"
                >
                </RadioButton>
            </UniformGrid>

            <usercontrols:KeyPad 
                x:Name="KeyPad"  Grid.Row="2" Focusable="True"
                cal:Message.Attach=" 
                [Event ValueChanged] = [Action OnKeyPadValueChanged(KeyPad.Value)]; 
                [Event InputComplete] = [Action OnKeyPadInputComplete(KeyPad.Result)]
            " 
                Width="498" Height="600"
                DisplayText="{Binding PinDisplay, Mode=OneWay}" 
            >
                <i:Interaction.Triggers>
                    <ei:DataTrigger Binding="{Binding IsSystemLocked,Mode=OneWay}" Value="True" >
                        <ei:ChangePropertyAction TargetName="KeyPad" PropertyName="Value" Value=""></ei:ChangePropertyAction>
                        <ei:ChangePropertyAction TargetName="KeyPad" PropertyName="Result" Value=""></ei:ChangePropertyAction>
                    </ei:DataTrigger>
                </i:Interaction.Triggers>
            </usercontrols:KeyPad>

        </Grid>
    </Grid>
</UserControl>

