<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Views.AdministrationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">
    <Grid x:Name="AdministrationViewRoot" FocusManager.IsFocusScope="True">
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource BackgroundGlobal}" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" MaxWidth="340" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="Back"
                Grid.Column="1"
                MaxWidth="300"
                MaxHeight="100"
                Margin="20"
                Panel.ZIndex="10"
                Style="{DynamicResource ButtonBaseStyle}">
                <DockPanel HorizontalAlignment="Stretch">
                    <fa:FontAwesome
                        Margin="15,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource H2}"
                        Icon="ArrowCircleOutlineLeft" />
                    <TextBlock
                        Margin="15,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource H3}"
                        Text="{lex:Loc Global_Back}" />
                </DockPanel>

            </Button>

        </Grid>


        <ContentControl
            x:Name="KeypadViewModel"
            Grid.Row="0"
            Panel.ZIndex="9" />
        <ContentControl
            x:Name="AdministrationConductorViewModel"
            Grid.Row="0"
            Panel.ZIndex="8"
            Visibility="{Binding IsAdministrationAccessApproved, Converter={StaticResource BoolToVisibilityConverter}}" />

    </Grid>
</UserControl>
