<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Settings.Views.TabItemSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:LeapVR.Shell.UI.Shell.SystemAdministration.Settings.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:LeapVR.Shell.Properties"
    xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource H4}" />
            <Setter Property="Margin" Value="20" />
        </-->
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <Grid>
                <Button
                    x:Name="OpenConnectionDialog"
                    Width="auto"
                    Height="auto"
                    Margin="20"
                    Style="{DynamicResource ButtonBaseStyle}">
                    <DockPanel HorizontalAlignment="Stretch">
                        <fa:FontAwesome
                            Margin="15,0"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource H5}"
                            Icon="IdCard"
                            Rotation="0" />
                        <TextBlock
                            Margin="15,0"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource H5}"
                            Text="{lex:Loc System_Settings_ConnectionPanel}" />
                    </DockPanel>
                </Button>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Margin="10"
                    FontSize="{DynamicResource H4}">
                    <TextBlock.Inlines>
                        <Run Foreground="{DynamicResource ThemeMainTextColor}" Text="{lex:Loc StationMode}" />
                        <Span Foreground="{DynamicResource ThemeMainTextColor}">:</Span>
                    </TextBlock.Inlines>
                </TextBlock>
                <ContentControl
                    x:Name="ModeSwitchViewModel"
                    Grid.Column="1"
                    FontSize="{DynamicResource H4}" />
            </Grid>
            <TextBlock Margin="20" FontSize="{DynamicResource H4}">
                <TextBlock.Inlines>
                    <Run Foreground="{DynamicResource ThemeMainTextColor}" Text="{lex:Loc StationMode_ForceRestartVrDriver}" />
                    <Span Foreground="{DynamicResource ThemeMainTextColor}">:</Span>
                    <usercontrols:SwitchButton
                        Height="{DynamicResource H5}"
                        Margin="5,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        IsSwitchOn="{Binding ForceVrDriverRestart, Mode=TwoWay, FallbackValue=False}" />
                </TextBlock.Inlines>
            </TextBlock>
            <TextBlock Margin="20" FontSize="{DynamicResource H4}">
                <TextBlock.Inlines>
                    <Run Foreground="{DynamicResource ThemeMainTextColor}" Text="{lex:Loc StationMode_VrDriverInteraction}" />
                    <Span Foreground="{DynamicResource ThemeMainTextColor}">:</Span>
                    <usercontrols:SwitchButton
                        Height="{DynamicResource H5}"
                        Margin="5,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        IsSwitchOn="{Binding VrDriverInteraction, Mode=TwoWay, FallbackValue=False}" />
                </TextBlock.Inlines>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
