<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Settings.Views.ModeSwitchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:LeapVR.Shell.UI.Core.Behaviors"
    xmlns:cal="http://www.caliburnproject.org"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <usercontrols:LeapDropDown
        cal:Message.Attach="[Event SelectionChanged] = [Action OnSelectedModeChanged($eventArgs)]"
        Background="Transparent"
        BorderBrush="{DynamicResource ThemeSecondaryTextColor}"
        BorderThickness="3"
        DisplayMemberPath="Value"
        IsEnabled="{Binding CanSelectMode}"
        ItemsSource="{Binding SupportedModes, Mode=OneWay}"
        PopupPlacement="Bottom"
        SelectedValue="{Binding SelectedMode, Mode=TwoWay}"
        SelectedValuePath="Key">
        <i:Interaction.Behaviors>
            <behaviors:SelectorHideSelectedItemBehavior />
        </i:Interaction.Behaviors>
    </usercontrols:LeapDropDown>
</UserControl>
