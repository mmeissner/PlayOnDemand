<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Statistics.Views.TabItemStatisticsGlobalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:language="clr-namespace:LeapVR.Shell.Language;assembly=LeapVR.Shell.Language" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:LeapVR.Shell.Properties"
    d:DesignHeight="1080" d:DesignWidth="1920"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource H3}" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0">
                <TextBlock.Inlines>
                    <Run FontSize="{DynamicResource H5}" Text="{lex:Loc System_Statistics_Global_TotalRuntime}" />
                    <Span FontSize="{DynamicResource H5}">:</Span>
                    <LineBreak />
                    <Run Text="{Binding TotalRuntime, FallbackValue='-'}" />
                </TextBlock.Inlines>
            </TextBlock>

            <TextBlock Grid.Row="1">
                <TextBlock.Inlines>
                    <Run FontSize="{DynamicResource H5}" Text="{lex:Loc System_Statistics_Global_LongestPlayedGame}" />
                    <Span FontSize="{DynamicResource H5}">:</Span>
                    <LineBreak />
                    <Run Text="{Binding LongestPlayedGame, FallbackValue='-'}" />
                </TextBlock.Inlines>
            </TextBlock>

            <TextBlock Grid.Row="2">
                <TextBlock.Inlines>
                    <Run FontSize="{DynamicResource H5}" Text="{lex:Loc System_Statistics_Global_LongestGameSession}" />
                    <Span FontSize="{DynamicResource H5}">:</Span>
                    <LineBreak />
                    <Run Text="{Binding LongestGameSession, FallbackValue='-'}" />
                </TextBlock.Inlines>
            </TextBlock>

            <TextBlock Grid.Row="3">
                <TextBlock.Inlines>
                    <Run FontSize="{DynamicResource H5}" Text="{lex:Loc System_Statistics_Global_MostPlayedGame}" />
                    <Span FontSize="{DynamicResource H5}">:</Span>
                    <LineBreak />
                    <Run Text="{Binding MostPlayedGame, FallbackValue='-'}" />
                </TextBlock.Inlines>
            </TextBlock>

        </Grid>
        <Button
            x:Name="ResetVrBoxStatistics"
            Grid.Row="1"
            MaxWidth="600" MaxHeight="80"
            BorderThickness="3"
            Content="{lex:Loc System_Statistics_Global_ResetVrBoxStatistics}"
            FontSize="{DynamicResource H3}"
            Style="{DynamicResource ButtonBaseStyle}" />
    </Grid>
</UserControl>
