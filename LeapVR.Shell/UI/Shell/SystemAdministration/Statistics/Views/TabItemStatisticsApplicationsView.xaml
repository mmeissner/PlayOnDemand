<UserControl
    x:Class="LeapVR.Shell.UI.Shell.SystemAdministration.Statistics.Views.TabItemStatisticsApplicationsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:properties="clr-namespace:LeapVR.Shell.Properties"
    d:DesignHeight="720" d:DesignWidth="1280"
    mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="GridViewCellTemplate">
            <TextBlock FontSize="{DynamicResource H4}" Text="{Binding}" TextAlignment="Center" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="10,0,10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="7*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <ListView
            x:Name="Items"
            HorizontalContentAlignment="Stretch"
            ItemContainerStyle="{DynamicResource ListViewItemForUniversalItem}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            Style="{DynamicResource ListViewStyleWithColumns}"
            VirtualizingPanel.ScrollUnit="Pixel">
            <ListView.View>
                <GridView AllowsColumnReorder="False">
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewColumnHeader">
                                        <Border Height="50" Background="White">
                                            <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource H5}" Text="{TemplateBinding Content}" TextAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>
                    <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=Items, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.05}" DisplayMemberBinding="{Binding Number}" Header="{lex:Loc System_Statistics_Applications_Columns_Number}" />
                    <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=Items, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.05}" DisplayMemberBinding="{Binding Thumbnail, Converter={StaticResource ImageConverter}}" />
                    <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=Items, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.2}" DisplayMemberBinding="{Binding Name}" Header="{lex:Loc System_Statistics_Applications_Columns_Name}" />
                    <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=Items, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.2}" DisplayMemberBinding="{Binding LastTimePlayed}" Header="{lex:Loc System_Statistics_Applications_Columns_LastTimePlayed}" />
                    <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=Items, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.15}" DisplayMemberBinding="{Binding TimesPlayed}" Header="{lex:Loc System_Statistics_Applications_Columns_TimesPlayed}" />
                    <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=Items, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.2}" DisplayMemberBinding="{Binding LongestSession}" Header="{lex:Loc System_Statistics_Applications_Columns_LongestSession}" />
                    <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=Items, Converter={StaticResource ProportionValueConverter}, ConverterParameter=0.15}" DisplayMemberBinding="{Binding TotalRuntime}" Header="{lex:Loc System_Statistics_Applications_Columns_TotalRuntime}" />
                </GridView>
            </ListView.View>
        </ListView>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock HorizontalAlignment="Right" FontSize="{DynamicResource H5}" Style="{DynamicResource TextBlockBaseStyle}" Text="{lex:Loc System_Statistics_Applications_Count}" />
            <TextBlock
                Grid.Column="1"
                Margin="50,0,50,0" HorizontalAlignment="Center"
                FontSize="{DynamicResource H5}"
                Style="{DynamicResource TextBlockBaseStyle}"
                Text="{Binding InstalledApplicationCount}" />
            <Button
                x:Name="ResetGameStatistics"
                Grid.Column="2"
                MaxWidth="400" MaxHeight="60"
                HorizontalAlignment="Right"
                Content="{lex:Loc System_Statistics_Applications_ResetApplicationsStatistics}"
                FontSize="{DynamicResource H5}"
                IsEnabled="{Binding CanResetGameStatistics}"
                Style="{DynamicResource ButtonBaseStyle}" />
        </Grid>
    </Grid>
</UserControl>

