<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Blocker.Views.InstallationShellBlockingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:LeapVR.Shell.Properties" xmlns:tz="http://schemas.abtsoftware.co.uk/transitionz"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DockPanel VerticalAlignment="Top">
            <Grid DockPanel.Dock="Top">
                <Image
                    Width="50"
                    Margin="15" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Source="{StaticResource IconLeapVrCube}" />
                <ContentControl
                    x:Name="AppThumbnail"
                    Width="460" Height="215"
                    Margin="0,80,0,10"
                    cal:View.Context="Normal" />
            </Grid>
            <TextBlock
                DockPanel.Dock="Top"
                FontSize="{DynamicResource H3}"
                FontWeight="Bold"
                Style="{DynamicResource TextBlockBaseStyle}"
                TextAlignment="Center">
                <TextBlock.Inlines>
                    <Run Text="{Binding AppName, Mode=OneWay}" />
                </TextBlock.Inlines>
            </TextBlock>

            <Grid DockPanel.Dock="Top">
                <DockPanel x:Name="InProgressDisplay" Visibility="{Binding IsEnded, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                    <Grid />
                    <TextBlock DockPanel.Dock="Top" FontSize="{DynamicResource H5}" Style="{DynamicResource TextBlockBaseStyle}" TextAlignment="Center">
                        <TextBlock.Inlines>
                            <Run Text="{Binding Information, Mode=OneWay}" />
                        </TextBlock.Inlines>
                    </TextBlock>
                </DockPanel>

                <Grid
                    d:IsHidden="True"
                    tz:Transitionz.Opacity="{tz:OpacityParams From=0,
                                                              To=1,
                                                              Duration=300,
                                                              TransitionOn=Visibility}"
                    tz:Transitionz.Translate="{tz:TranslateParams From='20,0',
                                                                  To='0,0',
                                                                  Duration=300,
                                                                  TransitionOn=Visibility}"
                    tz:Transitionz.Visibility="{Binding IsEnded, Converter={StaticResource BoolToVisibilityConverter}}"
                    Visibility="{Binding IsEnded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <DockPanel x:Name="CompleteDisplay" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                        <TextBlock DockPanel.Dock="Top" FontSize="{DynamicResource H3}" Style="{DynamicResource TextBlockBaseStyle}" TextAlignment="Center">
                            <TextBlock.Inlines>
                                <Run Text="{lex:Loc Installation_InstallationComplete}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                    </DockPanel>

                    <DockPanel x:Name="ErrorDisplay" Visibility="{Binding HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock DockPanel.Dock="Top" FontSize="{DynamicResource H3}" Style="{DynamicResource TextBlockBaseStyle}" TextAlignment="Center">
                            <TextBlock.Inlines>
                                <Run Text="{lex:Loc Shell_InstallationBlocking_Error}" />
                                <LineBreak />
                                <Run FontSize="{DynamicResource H5}" Text="{Binding Information, Mode=OneWay}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <Button
                            x:Name="Close"
                            Width="360" Height="60"
                            Margin="0,30"
                            Content="OK" DockPanel.Dock="Top"
                            FontSize="{DynamicResource H5}"
                            Style="{DynamicResource ButtonBaseStyle}" />
                    </DockPanel>
                </Grid>
            </Grid>

        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,20,0" HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock FontSize="{DynamicResource H3}" Foreground="{DynamicResource InstallViewsPrimaryPercentageTextForegroundColor}" Style="{DynamicResource TextBlockBaseStyle}" TextAlignment="Right">
                    <TextBlock.Inlines>
                        <Run Text="{Binding PercentageDone, Mode=OneWay}" />
                    </TextBlock.Inlines>
                </TextBlock>
                <TextBlock FontSize="{DynamicResource H3}" Foreground="{DynamicResource InstallViewsPrimaryPercentageTextForegroundColor}" Style="{DynamicResource TextBlockBaseStyle}" Text="%" />
            </StackPanel>
            <ProgressBar
                Grid.Row="1"
                Height="30"
                Margin="20,0,20,60"
                Maximum="100" Minimum="0"
                Visibility="{Binding PercentageVisibility}"
                Value="{Binding PercentageDone}" />
        </Grid>
    </Grid>
</UserControl>