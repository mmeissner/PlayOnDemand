<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Blocker.Views.AppExecutingShellBlockingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:fa="http://schemas.fontawesome.io/icons/" xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:usercontrols="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    d:DesignHeight="600" d:DesignWidth="1000"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="1" VerticalAlignment="Center">
            <ContentControl
                x:Name="AppThumbnail"
                Width="782" Height="365.5"
                cal:View.Context="Normal" DockPanel.Dock="Top" />

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    FontSize="{DynamicResource H2}"
                    Style="{DynamicResource TextBlockBaseStyle}"
                    TextAlignment="Center"
                    Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                    <fa:FontAwesome
                        VerticalAlignment="Center"
                        FontSize="80" Icon="Gear" Spin="True" SpinDuration="3.5" />
                </TextBlock>
                <TextBlock
                    MaxWidth="800"
                    Margin="0,0,30,0"
                    FontSize="{DynamicResource H2}"
                    Style="{DynamicResource TextBlockBaseStyle}"
                    Text="{Binding AppName, Mode=OneWay}"
                    TextAlignment="Left"
                    Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}" />
                <usercontrols:LeapButton
                    x:Name="Cancel"
                    Padding="100,20" HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderThickness="1" Focusable="True"
                    FontSize="{DynamicResource GuardViewsH4}"
                    Style="{DynamicResource GuardViewsButtonStyle}"
                    Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}}">

                    <usercontrols:LeapButton.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,15,0" VerticalAlignment="Center" Text="{lex:Loc Global_Cancel}" />
                            <TextBlock VerticalAlignment="Center" Visibility="{Binding EnableGamepadIndicator, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock.Inlines>
                                    <Image Width="60" Height="60" Source="{DynamicResource IconXboxControllerB}" />
                                </TextBlock.Inlines>
                            </TextBlock>
                        </StackPanel>
                    </usercontrols:LeapButton.Content>
                </usercontrols:LeapButton>
            </StackPanel>
        </DockPanel>
        <TextBlock
            Grid.Row="2"
            MaxWidth="800"
            Margin="0,0,30,0" HorizontalAlignment="Center"
            FontSize="{DynamicResource H4}"
            Style="{DynamicResource TextBlockBaseStyle}"
            Text="{Binding CurrentState, Mode=OneWay}"
            TextAlignment="Center" />
    </Grid>
</UserControl>