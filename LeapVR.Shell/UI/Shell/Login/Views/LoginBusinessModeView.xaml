<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Login.Views.LoginBusinessModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">

    <Grid x:Name="AwaitingPanel" Panel.ZIndex="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="154" />
            <RowDefinition Height="153" />
            <RowDefinition Height="*" />
            <RowDefinition Height="295" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition MinWidth="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ContentControl
            x:Name="LanguageSelect"
            Grid.Row="0"
            Grid.Column="2"
            Height="80"
            Margin="20"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Focusable="False" />
        <!--Image
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="0"
            Source="{lex:LocImage Business_BackgroundSplashLeft}"
            Stretch="Uniform" />
        <Image
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="2"
            Source="{lex:LocImage Business_BackgroundSplashRight}"
            Stretch="Uniform" /-->
        <Image
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Panel.ZIndex="-1"
            Source="{DynamicResource BusinessBackgroundSplashscreenTop}"
            Stretch="Uniform" />
        <Image
            x:Name="QrCodeImage"
            Grid.Row="2"
            Grid.Column="1"
            MaxWidth="{Binding QrCodeWidth}"
            MaxHeight="400"
            VerticalAlignment="Center"
            Panel.ZIndex="0"
            Source="{Binding QrCode, Mode=OneWay}"
            Stretch="Uniform">
            <Image.Effect>
                <DropShadowEffect
                    BlurRadius="80"
                    Direction="0"
                    ShadowDepth="1"
                    Color="Black" />
            </Image.Effect>
        </Image>
        <TextBlock
            x:Name="ButtomTips"
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Width="1000"
            Margin="0,0,0,50"
            VerticalAlignment="Bottom"
            FontSize="{DynamicResource LoginViewsH4}"
            Foreground="{DynamicResource LoginViewsPrimaryTextForegroundColor}"
            Text="{Binding Tip, Mode=OneWay}"
            TextAlignment="Center" />
    </Grid>

</UserControl>