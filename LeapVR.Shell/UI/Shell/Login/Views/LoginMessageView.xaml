<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Login.Views.LoginMessageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:LeapVR.Shell.UI.Shell.Login.Views" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1080" d:DesignWidth="1920"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="307" />
            <RowDefinition Height="*" />
            <RowDefinition Height="295" />
        </Grid.RowDefinitions>
        <ContentControl
            x:Name="LanguageSelect"
            Grid.Row="0"
            Height="80"
            Margin="20" HorizontalAlignment="Right" VerticalAlignment="Top"
            Focusable="False" />
        <Image x:Name="Image" Grid.Row="1" Source="{Binding Image, FallbackValue={StaticResource ImageOffline}, Mode=OneWay, TargetNullValue={StaticResource ImageOffline}}" Stretch="Uniform" />
        <!--
            Image
            Grid.Row="0" Grid.RowSpan="3"
            Panel.ZIndex="-10"
            Source="{DynamicResource OverlayBackground}"
            Stretch="Fill" /
        -->

        <TextBlock
            x:Name="Information"
            Grid.Row="2"
            Width="auto"
            Margin="50,0,50,50" VerticalAlignment="Bottom"
            FontSize="{DynamicResource LoginViewsH4}"
            Foreground="{DynamicResource LoginViewsPrimaryTextForegroundColor}"
            Text="{Binding Information, Mode=OneWay}"
            TextAlignment="Center" TextWrapping="Wrap" />

    </Grid>
</UserControl>
