<UserControl
    x:Class="LeapVR.Shell.UI.Shell.Login.Views.LoginIntentionPrepaidView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:LeapVR.Shell.UI.Usercontrols"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Storyboard x:Key="AlarmColorBlinking">
            <ColorAnimation
                AutoReverse="True"
                BeginTime="0:0:0.0"
                RepeatBehavior="Forever"
                Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                To="Green"
                Duration="0:0:1" />
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="PrepaidLoginIntentionViewRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="154" />
            <RowDefinition Height="153" />
            <RowDefinition Height="*" />
            <RowDefinition Height="295" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition MinWidth="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Image
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Panel.ZIndex="-1"
            Source="{DynamicResource BusinessBackgroundSplashscreenTop}"
            Stretch="Uniform" />
        <Grid
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="3">
            <StackPanel VerticalAlignment="Bottom" Orientation="Vertical">
                <UniformGrid
                    x:Name="PanelSessionRate"
                    Columns="1"
                    DockPanel.Dock="Top"
                    Rows="2">
                    <TextBlock
                        x:Name="RateDisplay"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource GuardViewsH1}"
                        Foreground="{DynamicResource GuardViewsPrimaryForegroundColor}"
                        TextAlignment="Center">
                        <TextBlock.Inlines>
                            <Run Text="{Binding Information, Mode=OneWay}" />
                        </TextBlock.Inlines>
                    </TextBlock>
                    <TextBlock
                        x:Name="AlarmDisplay"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource GuardViewsH5}"
                        Foreground="{StaticResource GuardViewsPrimaryForegroundColor}"
                        TextAlignment="Center"
                        Visibility="{Binding DisplayCountingDown, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock.Inlines>
                            <Run Text="{lex:Loc Global_SecondsToPrepare}" />
                            <Run Text="{Binding TimeLeftToAutoCancel, Mode=OneWay}" />
                            <Run Text="{lex:Loc Global_Unit_Sec}" />
                        </TextBlock.Inlines>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Control.Loaded">
                                <EventTrigger.Actions>
                                    <BeginStoryboard Storyboard="{StaticResource AlarmColorBlinking}" />
                                </EventTrigger.Actions>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </UniformGrid>

                <UniformGrid
                    x:Name="PanelLogin"
                    Columns="4"
                    DockPanel.Dock="Top"
                    FirstColumn="1"
                    Rows="1">
                    <local:LeapButton
                        Width="{DynamicResource GuardViewsButtonWidth}"
                        Height="{DynamicResource GuardViewsButtonHeight}"
                        cal:Message.Attach="[Event Click ] = [Action Cancel()]"
                        FontSize="{DynamicResource GuardViewsButtonFontSize}"
                        Style="{DynamicResource GuardViewsButtonStyle}">
                        <Button.Content>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <fa:FontAwesome
                                    Margin="15,0"
                                    VerticalAlignment="Center"
                                    FontSize="{Binding UiConfig.LoginButtonIconSize, Mode=OneWay}"
                                    Icon="Ban" />
                                <TextBlock Margin="15,0" VerticalAlignment="Center">
                                    <TextBlock.Inlines>
                                        <Run FontSize="{Binding UiConfig.LoginButtonFontSize, Mode=OneWay}" Text="{lex:Loc Global_Cancel}" />
                                    </TextBlock.Inlines>
                                </TextBlock>
                                <Image MaxWidth="{DynamicResource GuardViewsH4}" Source="{DynamicResource IconXboxControllerB}" />
                            </StackPanel>
                        </Button.Content>
                    </local:LeapButton>
                    <local:LeapButton
                        MaxWidth="{DynamicResource GuardViewsButtonWidth}"
                        MaxHeight="{DynamicResource GuardViewsButtonHeight}"
                        cal:Message.Attach="[Event Click] = [Action Login()]"
                        FontSize="{DynamicResource GuardViewsButtonFontSize}"
                        Style="{DynamicResource GuardViewsButtonStyle}">
                        <Button.Content>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <fa:FontAwesome
                                    Margin="15,0"
                                    VerticalAlignment="Center"
                                    FontSize="{Binding UiConfig.LoginButtonIconSize, Mode=OneWay}"
                                    Icon="PlayCircle" />
                                <TextBlock Margin="15,0" VerticalAlignment="Center">
                                    <TextBlock.Inlines>
                                        <Run FontSize="{Binding UiConfig.LoginButtonFontSize, Mode=OneWay}" Text="{lex:Loc ConfirmLoginIntention}" />
                                    </TextBlock.Inlines>
                                </TextBlock>
                                <Image MaxWidth="{DynamicResource GuardViewsH4}" Source="{DynamicResource IconXboxControllerA}" />
                            </StackPanel>
                        </Button.Content>
                    </local:LeapButton>
                </UniformGrid>
            </StackPanel>
        </Grid>
        <!--
            Image
            Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="3"
            Panel.ZIndex="-1"
            Source="{DynamicResource OverlayBackground}"
            Stretch="Fill" /
        -->

    </Grid>
</UserControl>