# PlayOnDemand server-stack secrets.
#
# Copy to .env and fill in real values BEFORE running `docker compose up`.
# The .env file is gitignored. Never commit secrets.

# ---- Postgres ----
POSTGRES_USER=pod_user
POSTGRES_PASSWORD=                    # required, strong random string
POSTGRES_DB=pod

# ---- First-run admin seed ----
ADMIN_USERNAME=superuser
ADMIN_EMAIL=                          # required, real email so password-reset works
ADMIN_PASSWORD=                       # required, satisfies Identity policy: digit + lower + upper + non-alphanumeric, length >= 10
STATION_PASSWORD=                     # required, default station-side password until rotated via the operator UI

# ---- JWT signing ----
# At least 32 ASCII bytes of high-entropy data. Rotating invalidates every currently-issued operator token.
JWT_SECRET=

# ---- Hostname ----
# Set to the public DNS name the server is reachable at.
# Used by ConfigShellServer (kiosk discovery), JWT Audience, LetsEncrypt SANs.
POD_HOSTNAME=localhost
POD_DISPLAY_NAME=PlayOnDemand

# ---- Operator web UIs ----
# After `docker compose up -d` the stack exposes two operator-facing web apps:
#   :80    REST + gRPC               (server container)
#   :443   TLS                       (server container, when LETSENCRYPT_ENABLED=true)
#   :8080  Minimal admin web UI      (operator container - login + station list + mint API keys)
#   :8081  Full daily-ops web UI     (operator-mobile container - tabbed station detail, all-sessions overview,
#                                     account password change, auto-polling state)
# Both UIs hit the same REST surface via nginx proxy in their respective containers.

# ---- Let's Encrypt ----
# Set LETSENCRYPT_ENABLED=true and provide a real public POD_HOSTNAME to get a free TLS cert.
# When disabled the server uses Kestrel's dev cert (the kiosk will refuse to connect).
LETSENCRYPT_ENABLED=false
LETSENCRYPT_ACCEPT_TOS=false          # Set to true after reading https://letsencrypt.org/repository/
LETSENCRYPT_EMAIL=                    # admin@your-domain.com; LE uses it for expiry warnings
LETSENCRYPT_ENCRYPTION_PASSWORD=      # encrypts the persisted ACME account key on disk under /app/certs
