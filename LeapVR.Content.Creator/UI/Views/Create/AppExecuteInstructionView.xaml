<UserControl
    x:Class="LeapVR.Content.Creator.UI.Views.AppExecuteInstructionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:LeapVR.Content.Creator.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="1280"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="{StaticResource ColumnWidthForBrowse}" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            HorizontalAlignment="Left">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc InstructionName}" />
                <ContentControl
                    Width="13"
                    Content="{lex:Loc InstructionName_Introduction}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="InstructionName"
            Grid.Row="3"
            Grid.Column="1"
            TextAlignment="Left"
            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        <Button
            Name="NameFromExecutable"
            Grid.Row="3"
            Grid.Column="2"
            Content="{lex:Loc SetFromExecutable}" />
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            HorizontalAlignment="Left">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc ApplicationMainExecutablePath}" />
                <ContentControl
                    Width="13"
                    Content="{lex:Loc ApplicationMainExecutablePath_Instruction}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="ApplicationMainExecutablePath"
            Grid.Row="0"
            Grid.Column="1"
            IsEnabled="False"
            IsReadOnly="True"
            TextAlignment="Left"
            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        <Button
            x:Name="BrowseApplicationStartingProcessExecutablePath"
            Grid.Row="0"
            Grid.Column="2"
            Content="{lex:Loc Global_Browse}" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            HorizontalAlignment="Left">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc WorkingDirectory}" />
                <ContentControl
                    Width="13"
                    Content="{lex:Loc WorkingDirectory_Introduction}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="ApplicationMainExecutableWorkingDirectory"
            Grid.Row="1"
            Grid.Column="1"
            IsEnabled="False"
            IsReadOnly="True"
            TextAlignment="Left"
            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        <Button
            x:Name="BrowseWorkingDirectoryFolder"
            Grid.Row="1"
            Grid.Column="2"
            Content="{lex:Loc Global_Browse}" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc ExecutableInfo_GameExecutableParameters}" />
                <ContentControl
                    Width="13"
                    Content="{lex:Loc ExecutableInfo_GameExecutableParametersInstruction}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="ApplicationMainExecutableParameters"
            Grid.Row="2"
            Grid.Column="1"
            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc RequiredVrModule}" />
                <ContentControl
                    Width="13"
                    Content="{lex:Loc RequiredVrModule_Introduction}"
                    ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <ComboBox
            Name="RequiredVrModules"
            Grid.Row="4"
            Grid.Column="1"
            DisplayMemberPath="DisplayName" />
        <GroupBox
            Grid.Row="5"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            FontSize="16"
            Header="{lex:Loc WatchdogOptions}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="{lex:Loc ProcessMonitoring}"
                    TextAlignment="Center" />
                <Grid
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Button Name="AddExecutable" Grid.Column="0">
                        <Button.Content>
                            <TextBlock Text="{lex:Loc Add}" />
                        </Button.Content>
                    </Button>
                    <Button Name="RemoveExecutable" Grid.Column="1">
                        <Button.Content>
                            <TextBlock Text="{lex:Loc Remove}" />
                        </Button.Content>
                    </Button>
                </Grid>
                <GroupBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    Header="{lex:Loc Options}">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="5"
                            TextAlignment="Left">
                            <TextBlock.Inlines>
                                <Run Text="{lex:Loc IsMainExecutable}" />
                                <ContentControl
                                    Width="13"
                                    Content="{lex:Loc IsMainExecutable_Introduction}"
                                    ContentTemplate="{DynamicResource InfoTemplate}" />
                            </TextBlock.Inlines>

                        </TextBlock>
                        <CheckBox
                            Name="IsMainExecutable"
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsChecked="{Binding Path=SelectedExecutable.IsMainExecutable}"
                            IsThreeState="False" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="5"
                            TextAlignment="Left">
                            <TextBlock.Inlines>
                                <Run Text="{lex:Loc KillOnExit}" />
                                <ContentControl
                                    Width="13"
                                    Content="{lex:Loc KillOnExit_Introduction}"
                                    ContentTemplate="{DynamicResource InfoTemplate}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <CheckBox
                            Name="KillOnExit"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsChecked="{Binding Path=SelectedExecutable.KillOnExit}"
                            IsEnabled="{Binding ElementName=IsMainExecutable, Path=IsChecked, Converter={StaticResource InvertBoolConverter}}"
                            IsThreeState="False" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="5"
                            TextAlignment="Left">
                            <TextBlock.Inlines>
                                <Run Text="{lex:Loc KillProcessIfNotResponding}" />
                                <ContentControl
                                    Width="13"
                                    Content="{lex:Loc KillProcessIfNotResponding_Introduction}"
                                    ContentTemplate="{DynamicResource InfoTemplate}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <CheckBox
                            Name="KillProcessOnNotResponding"
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsChecked="{Binding Path=SelectedExecutable.KillProcessOnNotResponding}"
                            IsEnabled="{Binding ElementName=IsMainExecutable, Path=IsChecked}"
                            IsThreeState="False" />
                    </Grid>
                </GroupBox>
                <GroupBox
                    Grid.Row="1"
                    Grid.Column="0"
                    Header="{lex:Loc Executables}">
                    <ListView Name="Executables">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=RelativeExecutableFilePath}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </GroupBox>
            </Grid>
        </GroupBox>
        <Grid
            Grid.Row="6"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Button
                Name="Ok"
                Grid.Column="0"
                Content="{lex:Loc Global_Ok}" />
            <Button
                Name="Cancel"
                Grid.Column="1"
                Content="{lex:Loc Global_Cancel}"
                Visibility="{Binding CancelButtonVisibility}" />
        </Grid>
    </Grid>
</UserControl>
