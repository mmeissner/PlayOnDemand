<UserControl
    x:Class="LeapVR.Content.Creator.UI.Views.LeapVrAppExecutableInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="480" d:DesignWidth="1280"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource ColumnWidthForCaption}" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="{StaticResource ColumnWidthForBrowse}" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc ExecutableInfo_GameBaseDirectory}" />
                <ContentControl Width="13" Content="{lex:Loc ExecutableInfo_GameBaseDirectoryInstruction}" ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="ApplicationRootDirectory"
            Grid.Row="0" Grid.Column="1"
            IsEnabled="{Binding IsPathManualEditEnabled}"
            IsReadOnly="{Binding IsPathManualEditEnabled, Converter={StaticResource InvertBoolConverter}}"
            TextAlignment="Left"
            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        <Button x:Name="BrowseApplicationRootDirectory" Grid.Row="0" Grid.Column="2" Content="{lex:Loc Global_Browse}" />
        <GroupBox
            Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            FontSize="16"
            Header="{lex:Loc ExecutionInstructions}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button Name="AddExecutionInstruction" Grid.Row="0" Grid.Column="0" Content="{lex:Loc Add}" />
                <Button Name="EditExecutionInstruction" Grid.Row="0" Grid.Column="1" Content="{lex:Loc Edit}" />
                <Button Name="RemoveExecutionInstruction" Grid.Row="0" Grid.Column="2" Content="{lex:Loc Remove}" />
                <ListView Name="ExecutionInstructions" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=InstructionName}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
