<UserControl
    x:Class="LeapVR.Content.Creator.UI.Views.AppDetailInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
    d:DesignHeight="550" d:DesignWidth="848"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource ColumnWidthForCaption}" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="{StaticResource ColumnWidthForBrowse}" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="170" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc Shell_SteamIdOptional}" />
                <ContentControl Width="13" Content="{lex:Loc Shell_SteamIDInstruction}" ContentTemplate="{StaticResource InfoTemplate}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox x:Name="SteamId" Grid.Row="0" Grid.Column="1" Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        <Button
            x:Name="ReacquireSteamData"
            Grid.Row="0" Grid.Column="2"
            Content="{lex:Loc Global_Reload}"
            IsEnabled="{Binding CanReacquireSteamData}" />

        <TextBlock Grid.Row="1" Grid.Column="0">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc DetailInfo_Title}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox
            x:Name="Title"
            Grid.Row="1" Grid.Column="1"
            IsEnabled="{Binding IsDataLoadingFromSteamId, Converter={StaticResource InvertBoolConverter}}"
            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        <ContentControl
            Grid.Row="1" Grid.Column="2"
            Height="30"
            HorizontalAlignment="Left"
            ContentTemplate="{StaticResource Spinner}"
            Visibility="{Binding IsDataLoadingFromSteamId, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!--TextBlock Grid.Row="2" Grid.Column="0">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc DetailInfo_Description}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </>
        <TextBox x:Name="Description" Grid.Row="2" Grid.Column="1" Validation.ErrorTemplate="{StaticResource ErrorTemplate}" /-->

        <TextBlock Grid.Row="3" Grid.Column="0">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc DetailInfo_Category}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <!--  TextBox x:Name="SelectedCategory" Grid.Row="3" Grid.Column="1" Validation.ErrorTemplate="{StaticResource ErrorTemplate}" /  -->
        <ComboBox
            x:Name="Categories"
            Grid.Row="3" Grid.Column="1"
            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
            IsEditable="False" />
        <!--  Tags are hidden as currently unused  -->
        <TextBlock Grid.Row="4" Grid.Column="0" Visibility="Collapsed">
            <TextBlock.Inlines>
                <Run Text="Tags" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <TextBox Name="Tags" Grid.Row="4" Grid.Column="1" Visibility="Collapsed" />
        <TextBlock Grid.Row="5" Grid.Column="1" Margin="{StaticResource MarginOfControl}" TextAlignment="Center">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc DetailInfo_ImageRecommendedSize}" />
                <Span>:</Span>
                <Span>460px * 215px</Span>
            </TextBlock.Inlines>
        </TextBlock>

        <TextBlock Grid.Row="6" Grid.Column="0">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc DetailInfo_Image}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>
        <Border
            x:Name="ImageViewer"
            Grid.Row="6" Grid.Column="1"
            Width="345" Height="170"
            Margin="{StaticResource MarginOfControl}"
            HorizontalAlignment="Center"
            cal:Message.Attach="[Event PreviewDrop] = [Action OnDrop($eventArgs)]" AllowDrop="True" Background="Transparent" BorderBrush="White"
            BorderThickness="1">
            <Image Width="345" Height="161" Source="{Binding Image}" Stretch="Fill" />
        </Border>
        <ContentControl
            Grid.Row="6" Grid.Column="2"
            Height="30"
            HorizontalAlignment="Left"
            ContentTemplate="{StaticResource Spinner}"
            Visibility="{Binding IsDataLoadingFromSteamId, Converter={StaticResource BoolToVisibilityConverter}}" />
        <Button
            x:Name="ImportImageFile"
            Grid.Row="6" Grid.Column="2"
            Content="{lex:Loc Global_Browse}"
            IsEnabled="{Binding IsDataLoadingFromSteamId, Converter={StaticResource InvertBoolConverter}}" />

        <TextBox
            Name="ImagePath"
            Grid.Row="7" Grid.Column="1"
            Margin="{DynamicResource MarginOfControl}"
            IsEnabled="False" IsReadOnly="True" TextAlignment="Left" TextWrapping="WrapWithOverflow"
            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />

    </Grid>
</UserControl>
