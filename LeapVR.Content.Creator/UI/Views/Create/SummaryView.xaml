<UserControl
    x:Class="LeapVR.Content.Creator.UI.Views.SummaryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:lex="http://wpflocalizeextension.codeplex.com" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="480" d:DesignWidth="848"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource ColumnWidthForCaption}" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="{StaticResource ColumnWidthForBrowse}" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            <RowDefinition Height="{StaticResource RowHeightOfGrid}" />

            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc Summary_OutputPackageName}" />
                <ContentControl Width="13" Content="{lex:Loc Summary_OutputPackageNameInstruction}" ContentTemplate="{DynamicResource InfoTemplate}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>

        <Button x:Name="BrowseOutputFilePath" Grid.Row="0" Grid.Column="2" Content="{lex:Loc Global_Browse}" />

        <TextBox
            Grid.Row="0" Grid.Column="1"
            IsEnabled="{Binding IsPathManualEditEnabled}"
            IsReadOnly="{Binding IsPathManualEditEnabled, Converter={StaticResource InvertBoolConverter}}"
            Text="{Binding OutputFilePath}"
            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Visibility="{Binding WasStarted, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc Summary_FileCount}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>

        <TextBlock Grid.Row="1" Grid.Column="1" TextAlignment="Left" Visibility="{Binding WasStarted, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} / {1}">
                    <Binding Path="DoneFilesCount" />
                    <Binding Path="TotalFilesCount" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Grid.Row="2" Grid.Column="0" Visibility="{Binding WasStarted, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock.Inlines>
                <Run Text="{lex:Loc Summary_TotalSize}" />
                <Span>:</Span>
            </TextBlock.Inlines>
        </TextBlock>

        <TextBlock Grid.Row="2" Grid.Column="1" TextAlignment="Left" Visibility="{Binding WasStarted, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} / {1}">
                    <Binding Converter="{StaticResource BytesToProperSpaceUnitConverter}" Path="DoneFilesSize" />
                    <Binding Converter="{StaticResource BytesToProperSpaceUnitConverter}" Path="TotalFilesSize" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <ProgressBar
            Name="DonePercents"
            Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
            Height="30"
            Margin="100,0"
            Maximum="100" Minimum="0" />

    </Grid>
</UserControl>
