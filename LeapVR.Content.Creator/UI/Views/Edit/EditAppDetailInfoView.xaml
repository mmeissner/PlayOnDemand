<UserControl
    x:Class="LeapVR.Content.Creator.UI.Views.EditAppDetailInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="http://www.caliburnproject.org"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
    d:DesignHeight="550"
    d:DesignWidth="848"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
                <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
                <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc DetailInfo_Title}" />
                    <Span>:</Span>
                </TextBlock.Inlines>
            </TextBlock>
            <TextBox
                x:Name="Title"
                Grid.Row="0"
                Grid.Column="1"
                Text="{Binding ContainerEditor.ContainerInfo.DisplayData.Name}"
                Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                HorizontalAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc DetailInfo_Description}" />
                    <Span>:</Span>
                </TextBlock.Inlines>
            </TextBlock>
            <TextBox
                x:Name="Description"
                Grid.Row="1"
                Grid.Column="1"
                Text="{Binding ContainerEditor.ContainerInfo.DisplayData.Description}"
                Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                HorizontalAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc DetailInfo_Category}" />
                    <Span>:</Span>
                </TextBlock.Inlines>
            </TextBlock>
            <TextBox
                x:Name="SelectedCategory"
                Grid.Row="2"
                Grid.Column="1"
                Text="{Binding ContainerEditor.ContainerInfo.DisplayData.Category}"
                Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        </Grid>
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
                <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
                <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
                <RowDefinition Height="{StaticResource RowHeightOfGrid}" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc DetailInfo_ApplicationGuid}" />
                    <Span>:</Span>
                </TextBlock.Inlines>
            </TextBlock>
            <TextBox
                x:Name="ApplicationGuid"
                Grid.Row="0"
                Grid.Column="1"
                IsEnabled="False"
                IsReadOnly="True"
                Text="{Binding ContainerEditor.ContainerInfo.ContainerApplicationGuid, Mode=OneWay}"
                TextAlignment="Center" />
            <Button
                Grid.Row="1"
                Grid.Column="1"
                Width="auto"
                HorizontalAlignment="Center"
                Content="{lex:Loc Global_GenerateNewGuid}" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                HorizontalAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc Global_ContainerVersion}" />
                    <Span>:</Span>
                </TextBlock.Inlines>
            </TextBlock>
            <TextBox
                x:Name="ContainerVersion"
                Grid.Row="2"
                Grid.Column="1"
                IsEnabled="False"
                IsReadOnly="True"
                Text="{Binding ContainerEditor.ContainerInfo.ContainerVersion, Mode=OneWay}"
                TextAlignment="Center"
                Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
            <TextBlock
                Grid.Row="3"
                Grid.Column="0"
                HorizontalAlignment="Left">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc Global_DiskSizeRequired}" />
                    <Span>:</Span>
                </TextBlock.Inlines>
            </TextBlock>
            <TextBox
                x:Name="TotalFileSize"
                Grid.Row="3"
                Grid.Column="1"
                IsEnabled="False"
                IsReadOnly="True"
                Text="{Binding ContainerEditor.ContainerInfo.TotalFilesSize, Converter={StaticResource BytesToProperSpaceUnitConverter}, Mode=OneWay}"
                TextAlignment="Center"
                Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
        </Grid>

        <StackPanel
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Orientation="Vertical">
            <TextBlock TextAlignment="Center">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc DetailInfo_Thumbnail_Image}" />
                    <Span>:</Span>
                </TextBlock.Inlines>
            </TextBlock>
            <TextBlock
                Margin="5"
                FontSize="10"
                TextAlignment="Center">
                <TextBlock.Inlines>
                    <Run Text="{lex:Loc DetailInfo_ImageRecommendedSize}" />
                    <Span>:</Span>
                    <Span>460px * 215px</Span>
                </TextBlock.Inlines>
            </TextBlock>
        </StackPanel>
        <Grid
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Height="Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />

            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Border
                x:Name="ImageViewerThumbnail"
                Grid.Row="0"
                Grid.Column="0"
                Width="345"
                Height="170"
                Margin="5"
                HorizontalAlignment="Center"
                cal:Message.Attach="[Event PreviewDrop] = [Action OnDrop($eventArgs)]"
                AllowDrop="True"
                Background="Transparent"
                BorderBrush="White"
                BorderThickness="1">
                <Image
                    Width="345"
                    Height="161"
                    Source="{Binding ContainerEditor.ContainerInfo.ThumbnailAsImage}"
                    Stretch="Fill" />
            </Border>

            <Button
                x:Name="ImportThumbnailImageFile"
                Grid.Row="1"
                Grid.Column="0"
                Content="{lex:Loc Global_Browse}" />

            <TextBox
                Name="ThumbnailImagePath"
                Grid.Row="2"
                Grid.Column="0"
                Margin="5"
                IsEnabled="False"
                IsReadOnly="True"
                TextAlignment="Left"
                TextWrapping="WrapWithOverflow"
                Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />

        </Grid>
    </Grid>
</UserControl>
