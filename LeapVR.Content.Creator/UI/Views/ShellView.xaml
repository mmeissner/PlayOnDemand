<Window
    x:Class="LeapVR.Content.Creator.UI.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:LeapVR.ContentCreator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="1120"
    Height="745"
    MinWidth="1120"
    MinHeight="665"
    lex:LocalizeDictionary.DesignCulture="en-US"
    lex:ResxLocalizationProvider.DefaultAssembly="LeapVR.Content.Creator.Language"
    lex:ResxLocalizationProvider.DefaultDictionary="Resources"
    FontFamily="Microsoft YaHei"
    Icon="{StaticResource Icon-Logo-Green}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources />
    <Grid>
        <Grid Panel.ZIndex="100" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle
                d:IsHidden="True"
                Fill="Black"
                Opacity="0.6" />
            <ContentControl Name="BusyViewModel" d:IsHidden="True" />
        </Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="150" />
                <RowDefinition Height="150" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Image
                Height="120"
                Source="{DynamicResource Banner-LeapVr}"
                Stretch="Uniform" />

            <UniformGrid
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Columns="2"
                Rows="1">
                <RadioButton
                    x:Name="English"
                    Width="190"
                    Height="Auto"
                    Margin="80,0,80,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    BorderThickness="0"
                    GroupName="Language"
                    IsChecked="{Binding CurrentCultureName, Mode=OneWay, Converter={StaticResource CultureMatchToBoolConverter}, ConverterParameter='en-US'}"
                    Style="{DynamicResource ImageRadioButtonBaseStyle}">
                    <RadioButton.Content>
                        <Image Source="{DynamicResource Icon-Flag-Us}" />
                    </RadioButton.Content>
                </RadioButton>
                <RadioButton
                    x:Name="Chinese"
                    Width="190"
                    Height="Auto"
                    Margin="80,0,80,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    BorderThickness="0"
                    GroupName="Language"
                    IsChecked="{Binding CurrentCultureName, Mode=OneWay, Converter={StaticResource CultureMatchToBoolConverter}, ConverterParameter='zh-CN'}"
                    Style="{DynamicResource ImageRadioButtonBaseStyle}">
                    <RadioButton.Content>
                        <Image Source="{DynamicResource Icon-Flag-Cn}" />
                    </RadioButton.Content>
                </RadioButton>
            </UniformGrid>

            <!--<TextBlock Grid.Row="0"
            VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"
            Text="Todo [FH]:Banner goes here"></TextBlock>-->

            <Grid
                Grid.Row="2"
                MinWidth="550"
                HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <DockPanel
                    Grid.Row="1"
                    Margin="0,0,0,10"
                    Dock="Right">

                    <!--  GroupBox FontSize="20" FontWeight="Bold" Header="{lex:Loc Shell_SelectPlatform}"  -->
                    <GroupBox FontSize="20" FontWeight="Bold">
                        <StackPanel>
                            <ComboBox
                                x:Name="Platforms"
                                Width="auto"
                                Margin="10"
                                IsSynchronizedWithCurrentItem="True"
                                ItemsSource="{Binding Platforms}"
                                SelectedValue="{Binding SelectedPlatform}"
                                Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                                Visibility="Collapsed" />
                            <Button
                                x:Name="GoCreate"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Width="Auto"
                                Height="60"
                                Margin="10"
                                HorizontalContentAlignment="Center"
                                Content="{lex:Loc Shell_StartCreation}"
                                FontSize="{DynamicResource H5}"
                                IsEnabled="{Binding CanGoCreate, Mode=OneWay}" />
                        </StackPanel>
                    </GroupBox>

                </DockPanel>
                <GroupBox
                    Grid.Row="2"
                    Width="auto"
                    FontSize="20"
                    FontWeight="Bold"
                    Header="{lex:Loc Shell_Tools}">
                    <Grid Width="auto">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="GoEdit"
                            Grid.Row="0"
                            Grid.Column="0"
                            Width="auto"
                            Height="60"
                            Margin="10"
                            Content="{lex:Loc Shell_StartEdit}"
                            FontSize="{DynamicResource H5}"
                            IsEnabled="{Binding CanGoEdit, Mode=OneWay}" />
                        <Button
                            x:Name="GoSplit"
                            Grid.Row="0"
                            Grid.Column="1"
                            Width="auto"
                            Height="60"
                            Margin="10"
                            Content="Unpack"
                            FontSize="{DynamicResource H5}"
                            IsEnabled="{Binding CanGoSplit, Mode=OneWay}" />
                    </Grid>
                </GroupBox>
            </Grid>

            <ContentControl
                x:Name="Wizard"
                Grid.Row="1"
                Grid.RowSpan="2"
                d:IsHidden="True" />
        </Grid>
    </Grid>
</Window>

