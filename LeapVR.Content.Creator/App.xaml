<Application x:Class="LeapVR.Content.Creator.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:LeapVR.ContentCreator">
    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Converters.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Images/Package.xaml" />
                <!--  IMPORTANT: If the Order changes, we will not be able to identify categories in code  -->
                <ResourceDictionary Source="pack://application:,,,/LeapVR.Shell.Categories;component/Resources/Images/Categories/Categories.xaml" />
                <ResourceDictionary>
                    <local:AppBootstrapper x:Key="Bootstrapper" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
