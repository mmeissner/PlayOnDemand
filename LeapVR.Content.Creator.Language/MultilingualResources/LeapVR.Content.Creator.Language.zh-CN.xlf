        </trans-unit>
        <trans-unit id="Complete_Error" translate="yes" xml:space="preserve">
          <source>Error</source>
          <target state="translated" state-qualifier="tm-suggestion">错误</target>
        </trans-unit>
        <trans-unit id="Complete_ErrorMessage" translate="yes" xml:space="preserve">
          <source>The VBox Installation Package creation process has encountered a problem. Please check validity of all provided data and try again.</source>
          <target state="translated">创建过程发生错误，请检查所有已指定的数据并重试。</target>
        </trans-unit>
        <trans-unit id="DetailInfo_Category" translate="yes" xml:space="preserve">
