        <trans-unit id="Global_ProductName" translate="yes" xml:space="preserve">
          <source>VBox Installation Package Creator</source>
          <target state="translated">VBox 安装包生成器</target>
        </trans-unit>
        <trans-unit id="Global_Reload" translate="yes" xml:space="preserve">
          <source>Reload</source>
          <target state="translated">加载</target>
