          <source>Name</source>
          <target state="translated">显示名称</target>
        </trans-unit>
        <trans-unit id="InstructionName_Introduction" translate="yes" xml:space="preserve">
          <source>A display name for one executable instruction that infers what's it about</source>
          <target state="translated">指定一个名字用以向用户展示该启动项隐含的意思</target>
        </trans-unit>
        <trans-unit id="SetFromExecutable" translate="yes" xml:space="preserve">
          <source>Set From Exe</source>
          <target state="translated">从 .exe 获取</target>
        </trans-unit>
        <trans-unit id="WorkingDirectory_Introduction" translate="yes" xml:space="preserve">
          <source>Working directory of a specific executable. If not set, working directory will be set to the directory where the executable is</source>
          <target state="translated">.exe 程序执行所依赖的工作目录，若为空，默认为可执行程序所在的目录</target>
        </trans-unit>
        <trans-unit id="IsMainExecutable" translate="yes" xml:space="preserve">
          <source>Is Main Executable</source>
          <target state="translated">是否为主要进程</target>
        </trans-unit>
        <trans-unit id="IsMainExecutable_Introduction" translate="yes" xml:space="preserve">
          <source>Indicates whether this executable is one of the executables taken into consideration to check if the application is running. Normally an application requires at least one main executable. Multiple main executables mean any of them running will the application be considered as running.</source>
          <target state="translated">指示该进程是否作为衡量应用程序正在运行的主要进程，通常情况下一个应用程序至少有一个主要进程，如果指定了多个主要进程，那么其中任何一个正在运行，系统将视作该应用程序正在运行</target>
        </trans-unit>
        <trans-unit id="KillOnExit" translate="yes" xml:space="preserve">
          <source>Kill On Application Exit</source>
          <target state="translated">应用退出时结束进程</target>
        </trans-unit>
        <trans-unit id="KillOnExit_Introduction" translate="yes" xml:space="preserve">
          <source>Indicates whether this process should be killed on application exit</source>
          <target state="translated">指示系统是否应该在应用退出时结束该进程</target>
        </trans-unit>
        <trans-unit id="KillProcessIfNotResponding" translate="yes" xml:space="preserve">
          <source>Kill on Not Responding</source>
          <target state="translated">进程无响应时强制结束</target>
        </trans-unit>
        <trans-unit id="KillProcessIfNotResponding_Introduction" translate="yes" xml:space="preserve">
          <source>Indicates whether this process should be killed when the system detects it is not responding</source>
          <target state="translated">指示系统是否在该进程无响应时强制结束该进程</target>
        </trans-unit>
        <trans-unit id="Options" translate="yes" xml:space="preserve">
          <source>Options</source>
          <target state="translated">选项</target>
        </trans-unit>
        <trans-unit id="ProcessMonitoring" translate="yes" xml:space="preserve">
          <source>Process Monitoring</source>
          <target state="translated">进程监控</target>
        </trans-unit>
        <trans-unit id="RequiredVrModule" translate="yes" xml:space="preserve">
          <source>Required VR Module</source>
          <target state="translated">依赖的 VR 模块</target>
        </trans-unit>
        <trans-unit id="RequiredVrModule_Introduction" translate="yes" xml:space="preserve">
          <source>Specify the corresponding vr module to match the correct graphic api.</source>
          <target state="translated">指定与该应用程序相匹配的 VR 模块</target>
        </trans-unit>
        <trans-unit id="WatchdogOptions" translate="yes" xml:space="preserve">
          <source>Watchdog Options</source>
          <target state="translated">检测选项</target>
        </trans-unit>
        <trans-unit id="Executables" translate="yes" xml:space="preserve">
          <source>Executables</source>
          <target state="translated">可执行程序</target>
        </trans-unit>
        <trans-unit id="NoneExecutableIsMainExecutable" translate="yes" xml:space="preserve">
          <source>None of added executables is marked as main executable, are you sure to continue?</source>
          <target state="translated">没有任何可执行程序被标记为起始 .exe，你确定要继续吗？</target>
        </trans-unit>
        <trans-unit id="Warning" translate="yes" xml:space="preserve">
          <source>Warning</source>
          <target state="translated">警告</target>
        </trans-unit>
      </group>
    </body>
  </file>
</xliff>