        <trans-unit id="Global_Validation_CannotBeEmpty" translate="yes" xml:space="preserve">
          <source>This field cannot be left empty.</source>
          <target state="translated">该字段不能为空</target>
        </trans-unit>
        <trans-unit id="Progress_CreatingFiles" translate="yes" xml:space="preserve">
          <source>Creating Files</source>
          <target state="translated">正在创建文件</target>
        </trans-unit>
        <trans-unit id="Progress_Done" translate="yes" xml:space="preserve">
          <source>Done</source>
          <target state="translated" state-qualifier="tm-suggestion">完成</target>
