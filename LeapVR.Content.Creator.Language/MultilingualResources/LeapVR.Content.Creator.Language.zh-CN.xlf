        </trans-unit>
        <trans-unit id="DetailInfo_Description" translate="yes" xml:space="preserve">
          <source>Description</source>
          <target state="translated" state-qualifier="tm-suggestion">说明</target>
        </trans-unit>
        <trans-unit id="DetailInfo_ExecutablePathNotRelative" translate="yes" xml:space="preserve">
          <source>Provided Executable File Path is not relative to Application Base Directory.</source>
          <target state="translated">指定的可执行文件路径与指定的游戏根目录不匹配</target>
        </trans-unit>
        <trans-unit id="DetailInfo_Image" translate="yes" xml:space="preserve">
