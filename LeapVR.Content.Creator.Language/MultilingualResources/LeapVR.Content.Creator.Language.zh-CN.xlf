        <trans-unit id="Shell_SelectPlatform" translate="yes" xml:space="preserve">
          <source>Select platform</source>
          <target state="translated">选择游戏平台</target>
        </trans-unit>
        <trans-unit id="Shell_StartCreation" translate="yes" xml:space="preserve">
          <source>Create</source>
          <target state="translated">创建</target>
        </trans-unit>
        <trans-unit id="Shell_SteamIDInstruction" translate="yes" xml:space="preserve">
          <source>Providing SteamID will allow Creator to automatically provide game Title and Image from Steam database.</source>
          <target state="translated">填入 SteamID，游戏名称和图片将自动从 Steam 上获取(确保英特网畅通)，可选</target>
        </trans-unit>
        <trans-unit id="Shell_SteamIdOptional" translate="yes" xml:space="preserve">
          <source>Steam ID (optional)</source>
          <target state="translated">Steam ID （可选）</target>
        </trans-unit>
        <trans-unit id="Shell_StemId" translate="yes" xml:space="preserve">
          <source>Steam ID</source>
          <target state="translated">Steam ID</target>
        </trans-unit>
        <trans-unit id="Summary_FileCount" translate="yes" xml:space="preserve">
          <source>Files Count</source>
          <target state="translated">文件数</target>
        </trans-unit>
        <trans-unit id="Summary_OutputPackageName" translate="yes" xml:space="preserve">
          <source>Package Output Path</source>
          <target state="translated">VBox 安装包输出路径</target>
        </trans-unit>
        <trans-unit id="Summary_OutputPackageNameInstruction" translate="yes" xml:space="preserve">
          <source>The output path that the installation package will be saved to when creation process is done. The installation package have `.vbox` extension.</source>
          <target state="translated">VBox 安装包创建完成后存储的目标路径，Vbox 安装包的扩展名为 '.vbox' </target>
        </trans-unit>
        <trans-unit id="Summary_TotalSize" translate="yes" xml:space="preserve">
          <source>Total Files Size</source>
          <target state="translated">总文件大小</target>
        </trans-unit>
        <trans-unit id="Global_Cancel" translate="yes" xml:space="preserve">
          <source>Cancel</source>
          <target state="translated">取消</target>
        </trans-unit>
        <trans-unit id="SupportedModes" translate="yes" xml:space="preserve">
          <source>Supported Modes</source>
          <target state="translated">支持模式</target>
        </trans-unit>
        <trans-unit id="DetailInfo_BeyondMaximumFileSizeFormat" translate="yes" xml:space="preserve">
          <source>The file you upload is beyond maximum allowed size: {0}</source>
          <target state="translated">该文件超出了最大允许的限制：{0}</target>
        </trans-unit>
        <trans-unit id="Summary_Output_FileAlreadyExists" translate="yes" xml:space="preserve">
          <source>File already exists, are you sure to override the file?</source>
          <target state="translated">文件已存在，确定要覆盖该文件吗？</target>
        </trans-unit>
        <trans-unit id="Global_Warning" translate="yes" xml:space="preserve">
          <source>Warning</source>
          <target state="translated">警告</target>
        </trans-unit>
        <trans-unit id="Validation_InvalidFilenameCharFormat" translate="yes" xml:space="preserve">
          <source>Invalid character detected in output path, it is replaced with '{0}' and you could adjust it.</source>
          <target state="translated">程序名称构造的输出路径存在非法字符，已用 '{0}' 替换，您仍然可以修改输出路径</target>
        </trans-unit>
        <trans-unit id="ApplicationMainExecutablePath" translate="yes" xml:space="preserve">
          <source>Application Main Executable Path</source>
          <target state="translated">.exe 路径</target>
        </trans-unit>
        <trans-unit id="ApplicationMainExecutablePath_Instruction" translate="yes" xml:space="preserve">
          <source>The path to the applixcation main executable file. Usually it is the application executable itself, for some applications requiring an external launcher this should be set the path to the launcher executable file.</source>
          <target state="translated">应用程序 .exe 文件路径，通常为该应用程序 .exe 文件本身</target>
        </trans-unit>
        <trans-unit id="ApplicationMainProcessName" translate="yes" xml:space="preserve">
          <source>Application Main Process Name</source>
          <target state="translated">程序起始进程名</target>
        </trans-unit>
        <trans-unit id="ApplicationMainProcessName_Instruction" translate="yes" xml:space="preserve">
          <source>Application main process name(usually the application executable file name without extension) is used to provide information for the shell to be aware of whether the application is started or not, is it still responding during lifetime and kill the application. Note this should not consider the launcher if there it is.</source>
          <target state="translated">应用程序主进程名用于检测该应用程序是否成功启动，无响应检测和退出应用程序，该值通常为应用程序本身 .exe 文件名去掉扩展名。注意，对于依赖 Launcher 的应用程序请将主进程设置为应用程序本身的进程名</target>
        </trans-unit>
        <trans-unit id="ApplicationProcessNames" translate="yes" xml:space="preserve">
          <source>Application Process Names</source>
          <target state="translated">预管理进程名</target>
        </trans-unit>
        <trans-unit id="ApplicationProcessNames_Instruction" translate="yes" xml:space="preserve">
          <source>Besides the application main process name, the application could have multiple different processes running during lifetime. Specify the process names if there are and split them with ";". This is optional</source>
          <target state="translated">除了应用程序主进程名以外，该程序可能在运行期间启动多个其他进程，使用英文半角 ';' 来分隔这些进程的名称，该选项不是必填项</target>
        </trans-unit>
        <trans-unit id="EnableRespondingDetection" translate="yes" xml:space="preserve">
          <source>Enable Responding Detection</source>
          <target state="translated">启用无响应检测</target>
        </trans-unit>
        <trans-unit id="EnableRespondingDetection_Instruction" translate="yes" xml:space="preserve">
          <source>Allow the shell to detect application responding and make further decision if it's not responding.</source>
          <target state="translated">允许系统在应用程序运行期间检测其响应状态，以帮助系统在程序长时间无响应时做出正确的决策</target>
        </trans-unit>
        <trans-unit id="EnableTrackingChildProcesses" translate="yes" xml:space="preserve">
          <source>Enable Tracking Child Processes</source>
          <target state="translated">启用子进程追踪</target>
        </trans-unit>
        <trans-unit id="EnableTrackingChildProcesses_Instruction" translate="yes" xml:space="preserve">
          <source>Allow the shell to track processes which are dynamically created since the starting process get executed. It is helpful when there're unknown amount of processes executed during an application running. However, this will slow the performance a little bit down.</source>
          <target state="translated">允许系统追踪应用程序运行期间动态创建的其他进程，但这将轻微损耗性能。当该选项启用时，系统将忽略进程名作为识别应用程序的依据</target>
        </trans-unit>
        <trans-unit id="Shell_StartEdit" translate="yes" xml:space="preserve">
          <source>Edit</source>
          <target state="translated">编辑</target>
        </trans-unit>
        <trans-unit id="Validation_ErrorVBoxPackageOpenEdit" translate="yes" xml:space="preserve">
          <source>An error occured on opening the VBox Package Files. /n Please check if all files are in place and not corrupt. </source>
          <target state="translated">打开 VBox 安装包文件时出错 /n 请检查是否所有文件定位正确并完好</target>
        </trans-unit>
        <trans-unit id="Validation_VBoxPackage_Edit_MsgBox_Error_Caption" translate="yes" xml:space="preserve">
          <source>Error during open VBox Package</source>
          <target state="translated">打开 VBox 安装包文件时出错</target>
        </trans-unit>
        <trans-unit id="DetailInfo_Thumbnail_Image" translate="yes" xml:space="preserve">
