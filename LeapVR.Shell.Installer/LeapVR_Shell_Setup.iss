; Script generated by the Inno Script Studio Wizard.
; SEE THE DOCUMENTATION FOR DETAILS ON CREATING INNO SETUP SCRIPT FILES!

#define MyAppName "Leap Play"
#define MyAppNameExt ".vbox"
#define MyAppDataDirectory "LeapPlay"
#define ShellName "Leap Play"
#define ShellConfigName "Config"
#define ContentCreator "Content Creator"
#define MyAppPublisher "Leap Play"
#define MyAppURL "https://www.example.com/"
#define ShellExeName "LeapPlay.Shell.exe"
#define ContentCreatorExeName "LeapPlay.Content.Creator.exe"
#define ShellVersionDirectory "Binaries"
#define DotNetRuntimeExe "NDP471-KB4033344-Web.exe"
#define MyAppVersion "UNKNOWN_VERSION"
#define ShellSourceDirectory "SHELL_SOURCE_DIR"
#define InstallerDirectory "INSTALLER_SOURCE_DIR"

[Setup]
; NOTE: The value of AppId uniquely identifies this application.
; Do not use the same AppId value in installers for other applications.
; (To generate a new GUID, click Tools | Generate GUID inside the IDE.)
SignTool=MsSign $f
AppId={{7AF3D759-713F-4F4E-B5D1-BF331AACA4BB}
AppName={#MyAppName}
AppVersion={#MyAppVersion}
;AppVerName={#MyAppName} {#MyAppVersion}
AppPublisher={#MyAppPublisher}
AppPublisherURL={#MyAppURL}
AppSupportURL={#MyAppURL}
AppUpdatesURL={#MyAppURL}
DefaultDirName={pf}\{#MyAppName}
DefaultGroupName={#MyAppName}
LicenseFile={#ShellSourceDirectory}InstallDir\License\License.rtf
OutputDir={#InstallerDirectory}Setup
OutputBaseFilename=LeapPlay_Setup
SetupIconFile={#InstallerDirectory}Resources\favicon.ico
WizardSmallImageFile={#InstallerDirectory}Resources\RightCornerImage.bmp
WizardImageFile={#InstallerDirectory}Resources\WizardBannerLeft.bmp
UninstallDisplayIcon={uninstallexe}
Compression=lzma
SolidCompression=yes
MinVersion=10.0.14393
PrivilegesRequired=admin
ArchitecturesAllowed=x64
ArchitecturesInstallIn64BitMode=x64
ChangesAssociations = yes

[Registry]
Root: HKCR; Subkey: "{#MyAppNameExt}"; ValueData: "{#MyAppName}"; Flags: uninsdeletevalue; ValueType: string; ValueName: ""
Root: HKCR; Subkey: "{#MyAppName}"; ValueData: "Program {#MyAppName}";  Flags: uninsdeletekey; ValueType: string;  ValueName: ""
Root: HKCR; Subkey: "{#MyAppName}\DefaultIcon"; ValueData: "{app}\{#ShellExeName},0"; ValueType: string;  ValueName: ""
;Root: HKCR; Subkey: "{#MyAppName}\shell\open\command";  ValueData: """{app}\{#MyAppExeName}"" ""%1""";  ValueType: string;  ValueName: ""

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"
Name: "chinese_simplified"; MessagesFile: "compiler:Languages\ChineseSimplified.isl"

[CustomMessages]
english.InstallingDotNetFramework=Installing .NET Framework. This might take a few minutes...
english.DotNetFrameworkFailedToLaunch=Failed to launch .NET Framework Installer with error "%1". Please fix the error then run this installer again.
english.DotNetFrameworkFailed1602=.NET Framework installation was cancelled. This installation can continue, but be aware that this application may not run unless the .NET Framework installation is completed successfully.
english.DotNetFrameworkFailed1603=A fatal error occurred while installing the .NET Framework. Please fix the error, then run the installer again.
english.DotNetFrameworkFailed5100=Your computer does not meet the requirements of the .NET Framework. Please consult the documentation.
english.DotNetFrameworkFailedOther=The .NET Framework installer exited with an unexpected status code "%1". Please review any other messages shown by the installer to determine whether the installation completed successfully, and abort this installation and fix the problem if it did not.
english.UninstallationTasks=Running Uninstallation Tasks
english.UninstallationTasksFailedToLaunch=Failed to launch Uninstallation Tasks
english.UninstallButtonCaption=Uninstall
english.UninstallFirstPageCaption=Press Uninstall to proceeed with uninstallation.
english.UninstallWelcomeText=Welcome to the Leap Play Uninstall wizard
english.UninstallDescriptionA=This will uninstall Leap Play Shell from your computer.
english.UninstallDescriptionB=It is recommended that your close all other applications before continuing.
english.UninstallDescriptionC=Click Next to continue, or Cancel to exit Uninstall.
english.UninstallKeepLicense=Keep License.
english.UninstallDeleteGames=Delete Games.


chinese_simplified.InstallingDotNetFramework=正在安装.NET 框架，可能需要几分钟时间...
chinese_simplified.DotNetFrameworkFailedToLaunch=安装.NET 框架失败 "%1"。请成功安装后，重新运行此程序。
